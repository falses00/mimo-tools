{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "swarm-master",
  "instructions": [
    ".harness/HARNESS_DRIVER.md",
    ".harness/AGENT_PROTOCOL.md"
  ],
  "permission": {
    "*": "allow",
    "edit": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "skill": { "*": "allow" },
    "task": { "*": "allow" },
    "bash": {
      "*": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git push*": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "gh *": "allow",
      "curl *": "allow",
      "grep *": "allow",
      "find *": "allow",
      "mkdir *": "allow",
      "cat *": "allow",
      "rm -rf*": "deny",
      "sudo *": "deny",
      "curl *| sh": "deny",
      "git push --force*": "deny"
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true
    },
    "supabase": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest"
      ],
      "enabled": true,
      "environment": {
        "SUPABASE_ACCESS_TOKEN": "{env:SUPABASE_ACCESS_TOKEN}"
      }
    },
    "vercel": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "vercel-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "VERCEL_TOKEN": "{env:VERCEL_TOKEN}"
      }
    },
    "sentry": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sentry/mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "SENTRY_AUTH_TOKEN": "{env:SENTRY_AUTH_TOKEN}"
      }
    },
    "figma": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp@latest"
      ],
      "enabled": true,
      "environment": {
        "FIGMA_ACCESS_TOKEN": "{env:FIGMA_ACCESS_TOKEN}"
      }
    },
    "linear": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "linear-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "LINEAR_API_KEY": "{env:LINEAR_API_KEY}"
      }
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "NOTION_API_KEY": "{env:NOTION_API_KEY}"
      }
    },
    "resend": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "resend-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "RESEND_API_KEY": "{env:RESEND_API_KEY}"
      }
    },
    "upstash": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "UPSTASH_REDIS_REST_URL": "{env:UPSTASH_REDIS_REST_URL}",
        "UPSTASH_REDIS_REST_TOKEN": "{env:UPSTASH_REDIS_REST_TOKEN}"
      }
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@context7/mcp@latest"
      ],
      "enabled": true
    },
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search@latest"
      ],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory@latest"
      ],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem@latest"
      ],
      "enabled": true,
      "args": [
        "--allowed-directories",
        "I:\\MIMO"
      ]
    },
    "sqlite": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sqlite@latest"
      ],
      "enabled": true
    },
    "puppeteer": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-puppeteer@latest"
      ],
      "enabled": true
    },
    "everything": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-everything@latest"
      ],
      "enabled": true
    }
  },
  "agent": {
    "swarm-master": {
      "description": "主控多 Agent 编排器：循环规划、审核、分派、执行、测试、部署，直到项目验收通过。",
      "mode": "primary",
      "temperature": 0.15,
      "steps": 120,
      "prompt": "{file:.opencode/prompts/swarm-master.md}",
      "permission": {
        "*": "allow",
        "task": { "*": "allow" },
        "bash": {
          "*": "allow",
          "git push*": "ask",
          "gh repo create*": "ask",
          "gh repo delete*": "ask",
          "rm -rf *": "ask",
          "sudo *": "ask",
          "curl * | sh*": "ask",
          "wget * | sh*": "ask"
        }
      }
    },
    "planner-agent": {
      "description": "负责读取项目状态、PRD、架构文档和任务文档，生成下一轮 3-7 个可执行任务。",
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 40,
      "prompt": "{file:.opencode/prompts/planner-agent.md}"
    },
    "critic-agent": {
      "description": "负责审核规划、代码变更、架构一致性、验收标准是否满足。",
      "mode": "subagent",
      "temperature": 0.05,
      "steps": 40,
      "prompt": "{file:.opencode/prompts/critic-agent.md}"
    },
    "task-dispatcher": {
      "description": "负责把审核通过的计划拆成可执行任务，写入 TASKS.md。",
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 40,
      "prompt": "{file:.opencode/prompts/task-dispatcher.md}"
    },
    "builder-agent": {
      "description": "负责实现功能、写代码、修复构建错误、补测试，不负责最终发布。",
      "mode": "subagent",
      "temperature": 0.2,
      "steps": 80,
      "prompt": "{file:.opencode/prompts/builder-agent.md}"
    },
    "ui-agent": {
      "description": "负责精美前端、响应式布局、暗色模式、组件一致性、可访问性。",
      "mode": "subagent",
      "temperature": 0.25,
      "steps": 60,
      "prompt": "{file:.opencode/prompts/ui-agent.md}"
    },
    "qa-agent": {
      "description": "负责 typecheck、lint、test、build、Playwright 验收和失败修复建议。",
      "mode": "subagent",
      "temperature": 0.05,
      "steps": 60,
      "prompt": "{file:.opencode/prompts/qa-agent.md}"
    },
    "security-agent": {
      "description": "负责检查 .env、token、密钥泄露、危险命令、GitHub 发布风险。",
      "mode": "subagent",
      "temperature": 0.05,
      "steps": 40,
      "prompt": "{file:.opencode/prompts/security-agent.md}"
    },
    "release-agent": {
      "description": "负责 changelog、commit、GitHub repo、GitHub Pages、Actions 部署；高风险步骤需确认。",
      "mode": "subagent",
      "temperature": 0.1,
      "steps": 60,
      "prompt": "{file:.opencode/prompts/release-agent.md}"
    }
  }
}