# MIMO API Configuration

# Frontend API Base URL
# For local development: http://localhost:8787
# For Render deployment: https://mimo-tools-api.onrender.com
# For Supabase Edge Functions: https://<project-ref>.supabase.co/functions/v1/mimo-api
PUBLIC_API_BASE_URL=

# CORS Origin (for backend)
CORS_ORIGIN=https://falses00.github.io

# Data directory for local storage
MIMO_DATA_DIR=.data

# Server port
PORT=8787

# GitHub Token (optional, for RepoLens GitHub API)
GITHUB_TOKEN=

# Supabase Configuration (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# WARNING: SUPABASE_SERVICE_ROLE_KEY should only be used in backend/Edge Functions
# Never expose this to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# MiMo v2.5 API Configuration (Xiaomi)
# ============================================================
# Base URL (OpenAI API compatible)
MIMO_API_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=
MIMO_MODEL=MiMo-V2.5-Pro

# Or use standard OpenAI configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
OPENAI_MODEL=MiMo-V2.5-Pro

# Anthropic API compatible endpoint
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://token-plan-sgp.xiaomimimo.com/anthropic

# ============================================================
# Available MiMo Models (choose the best for your use case)
# ============================================================
# MiMo-V2.5-Pro      - Best for code generation, analysis, complex tasks
# MiMo-V2.5          - Standard version, good balance of speed and quality
# MiMo-V2.5-TTS-VoiceClone  - Text-to-speech with voice cloning
# MiMo-V2.5-TTS-VoiceDesign - Text-to-speech with voice design
# MiMo-V2.5-TTS      - Standard text-to-speech
# MiMo-V2-Pro        - Previous generation pro model
# MiMo-V2-Omni       - Multimodal model
# MiMo-V2-TTS        - Previous generation TTS

# Embedding Model (optional, for pgvector embeddings)
EMBEDDING_MODEL=text-embedding-3-small

# Node Environment
NODE_ENV=development