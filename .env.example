# MIMO API Configuration

# API Base URL for frontend
PUBLIC_API_BASE_URL=http://localhost:8787

# GitHub Token (optional, for RepoLens GitHub API)
GITHUB_TOKEN=

# OpenAI API Key (optional, for KnowledgeBase Studio RAG)
OPENAI_API_KEY=

# Data directory for local storage
MIMO_DATA_DIR=.data

# Server port
PORT=8787
