# MIMO API Configuration

# Frontend API Base URL
# For local development: http://localhost:8787
# For Render deployment: https://mimo-tools-api.onrender.com
# For Supabase Edge Functions: https://<project-ref>.supabase.co/functions/v1/mimo-api
PUBLIC_API_BASE_URL=

# CORS Origin (for backend)
CORS_ORIGIN=https://falses00.github.io

# Data directory for local storage
MIMO_DATA_DIR=.data

# Server port
PORT=8787

# GitHub Token (optional, for RepoLens GitHub API)
GITHUB_TOKEN=

# Supabase Configuration (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# WARNING: SUPABASE_SERVICE_ROLE_KEY should only be used in backend/Edge Functions
# Never expose this to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# MiMo v2.5 API Configuration (Xiaomi)
# OpenAI API compatible endpoint
MIMO_API_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=
# Or use standard OpenAI configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1

# Embedding Model (optional, for pgvector embeddings)
EMBEDDING_MODEL=text-embedding-3-small

# Node Environment
NODE_ENV=development