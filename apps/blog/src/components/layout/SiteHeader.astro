---
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;

const { pathname } = Astro.url;
const relativePath = pathname.replace(baseWithSlash, '/').replace('//', '/');

const isHome = relativePath === '/' || relativePath === '';
const isProjects = relativePath.startsWith('/projects');
const isTools = relativePath.startsWith('/tools');
const isBlog = relativePath.startsWith('/blog');
const isWorkbench = relativePath.startsWith('/workbench');
const isAbout = relativePath === '/about';

const navItems = [
  { href: baseWithSlash, label: '首页', active: isHome },
  { href: `${baseWithSlash}projects`, label: '旗舰项目', active: isProjects },
  { href: `${baseWithSlash}tools`, label: '工具', active: isTools },
  { href: `${baseWithSlash}workbench`, label: '工作台', active: isWorkbench },
  { href: `${baseWithSlash}blog`, label: '博客', active: isBlog },
  { href: `${baseWithSlash}about`, label: '关于', active: isAbout },
];
---

{/* Desktop Navigation - Floating Pill */}
<nav class="hidden md:block fixed top-6 left-1/2 -translate-x-1/2 z-50">
  <div class="max-w-3xl">
    <div class="nav-pill flex items-center justify-between gap-8 px-6 py-2.5">
      {/* Logo */}
      <a href={baseWithSlash} class="flex items-center gap-2 group shrink-0">
        <span class="text-lg font-bold tracking-tight transition-all duration-200 group-hover:scale-105" style="color: var(--gold-primary);">
          MIMO
        </span>
      </a>

      {/* Nav Links */}
      <div class="flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-200',
              item.active 
                ? 'text-[var(--gold-primary)] bg-[var(--gold-subtle)]' 
                : 'text-[var(--text-muted)] hover:text-[var(--text-primary)]'
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>

      {/* Right Actions */}
      <div class="flex items-center gap-2">
        <ThemeToggle />
        <a
          href="https://github.com/falses00/mimo-tools"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center w-8 h-8 rounded-full transition-all duration-200 text-[var(--text-muted)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-hover)]"
          aria-label="GitHub"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
            <path d="M9 18c-4.51 2-5-2-7-2" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</nav>

{/* Mobile Navigation - Bottom Bar */}
<nav class="md:hidden fixed bottom-4 left-0 right-0 z-50 flex justify-center px-4">
  <div class="mobile-nav-pill flex items-center gap-1 px-2 py-2">
    {navItems.slice(0, 5).map(item => (
      <a
        href={item.href}
        class:list={[
          'relative w-12 h-12 flex items-center justify-center rounded-full transition-all duration-300',
          item.active 
            ? 'text-[var(--gold-primary)]' 
            : 'text-[var(--text-muted)] hover:text-[var(--text-primary)]'
        ]}
      >
        {item.active && (
          <div class="absolute inset-0 bg-[var(--gold-subtle)] rounded-full -z-10"></div>
        )}
        {item.label === '首页' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
            <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          </svg>
        )}
        {item.label === '旗舰项目' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
            <path d="M2 17l10 5 10-5"></path>
            <path d="M2 12l10 5 10-5"></path>
          </svg>
        )}
        {item.label === '工具' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.106-3.105c.32-.322.863-.22.983.218a6 6 0 0 1-8.259 7.057l-7.91 7.91a1 1 0 0 1-2.999-3l7.91-7.91a6 6 0 0 1 7.057-8.259c.438.12.54.662.219.984z"></path>
          </svg>
        )}
        {item.label === '博客' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 7v14"></path>
            <path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"></path>
          </svg>
        )}
        {item.label === '工作台' && (
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2"></rect>
            <path d="M3 9h18"></path>
            <path d="M9 21V9"></path>
          </svg>
        )}
      </a>
    ))}
  </div>
</nav>

<style>
  .nav-pill {
    background: rgba(11, 13, 18, 0.8);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 9999px;
    box-shadow: 
      0 0 30px rgba(0, 0, 0, 0.3),
      0 0 20px rgba(212, 175, 55, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  
  .mobile-nav-pill {
    background: rgba(11, 13, 18, 0.9);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    box-shadow: 
      0 20px 50px rgba(0, 0, 0, 0.5),
      0 0 20px rgba(212, 175, 55, 0.05);
  }
</style>

<script>
  // No mobile menu toggle needed for bottom nav
</script>