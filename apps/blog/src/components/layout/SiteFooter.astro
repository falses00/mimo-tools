---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: '/tools', label: '工具' },
  { href: '/blog', label: '博客' },
  { href: '/about', label: '关于' },
];

const socialLinks = [
  {
    href: 'https://github.com/falses00/mimo-tools',
    label: 'GitHub',
    icon: 'github',
  },
];
---

<footer style="background: var(--bg-section); border-top: 1px solid var(--border-subtle);">
  <div class="container py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 mb-4">
          <span class="text-xl font-bold" style="color: var(--gold-primary);">MIMO</span>
          <span class="text-xs font-medium px-2 py-0.5 rounded-full" style="background: var(--gold-subtle); color: var(--gold-soft); border: 1px solid var(--gold-border);">
            Tools
          </span>
        </a>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
          个人工具生态：包含多个实用工具、博客和导航站。所有工具纯前端处理，数据不离开浏览器。
        </p>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">快速链接</h3>
        <ul class="space-y-2">
          {footerLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-sm transition-colors duration-200"
                style="color: var(--text-muted);"
                onmouseover="this.style.color='var(--gold-primary)'"
                onmouseout="this.style.color='var(--text-muted)'"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Social & Contact -->
      <div>
        <h3 class="text-sm font-semibold mb-4" style="color: var(--text-primary);">联系方式</h3>
        <div class="flex gap-3">
          {socialLinks.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-lg transition-all duration-200"
              style="background: var(--bg-elevated); border: 1px solid var(--border-subtle); color: var(--text-muted);"
              onmouseover="this.style.borderColor='var(--gold-border)'; this.style.color='var(--gold-primary)'"
              onmouseout="this.style.borderColor='var(--border-subtle)'; this.style.color='var(--text-muted)'"
              aria-label={link.label}
            >
              {link.icon === 'github' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                  <path d="M9 18c-4.51 2-5-2-7-2" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8" style="border-top: 1px solid var(--border-subtle);">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-xs" style="color: var(--text-muted);">
          &copy; {currentYear} MIMO. Built with{' '}
          <a href="https://astro.build" target="_blank" rel="noopener noreferrer" style="color: var(--gold-soft);">Astro</a>
          {' '}and{' '}
          <a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer" style="color: var(--gold-soft);">Tailwind CSS</a>.
        </p>
        <p class="text-xs" style="color: var(--text-disabled);">
          All tools process data locally in your browser.
        </p>
      </div>
    </div>
  </div>
</footer>