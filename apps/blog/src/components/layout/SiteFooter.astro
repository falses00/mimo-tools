---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border/40 bg-background/95">
  <div class="container flex flex-col items-center justify-between gap-4 py-10 md:h-24 md:flex-row md:py-0">
    <div class="flex flex-col items-center gap-4 px-8 md:flex-row md:gap-2 md:px-0">
      <p class="text-center text-sm leading-loose text-muted-foreground md:text-left">
        &copy; {currentYear} MIMO. Built with{' '}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium underline underline-offset-4"
        >
          Astro
        </a>{' '}
        and{' '}
        <a
          href="https://tailwindcss.com"
          target="_blank"
          rel="noopener noreferrer"
          class="font-medium underline underline-offset-4"
        >
          Tailwind CSS
        </a>.
      </p>
    </div>
    <div class="flex items-center space-x-4">
      <a
        href="https://github.com/falses00/mimo-tools"
        target="_blank"
        rel="noopener noreferrer"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
          <path d="M9 18c-4.51 2-5-2-7-2" />
        </svg>
      </a>
      <a
        href="/blog"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        博客
      </a>
      <a
        href="/tools"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        工具
      </a>
      <a
        href="/about"
        class="text-muted-foreground hover:text-foreground transition-colors"
      >
        关于
      </a>
    </div>
  </div>
</footer>