---
interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---

<div class="section">
  <div class="container">
    {/* Header */}
    <div class="mb-8">
      <a href="/tools" class="inline-flex items-center gap-2 text-sm mb-4 transition-colors duration-200" style="color: var(--text-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7" />
          <path d="M19 12H5" />
        </svg>
        返回工具箱
      </a>
      <div class="flex items-center gap-4">
        {icon && (
          <div class="flex items-center justify-center w-12 h-12 rounded-xl" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
            <span class="text-2xl" style="color: var(--gold-primary);">{icon}</span>
          </div>
        )}
        <div>
          <h1 class="text-3xl font-bold" style="color: var(--text-primary);">{title}</h1>
          <p class="mt-1" style="color: var(--text-muted);">{description}</p>
        </div>
      </div>
    </div>

    {/* Content */}
    <div class="rounded-xl p-6 lg:p-8" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
      <slot />
    </div>

    {/* Status Bar */}
    <div id="status-bar" class="mt-4 p-3 rounded-lg text-sm hidden"></div>

    {/* Tips Section */}
    <div class="mt-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
      <slot name="tips" />
    </div>
  </div>
</div>

<script>
  // Global status bar handler
  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    const statusBar = document.getElementById('status-bar');
    if (!statusBar) return;
    
    statusBar.className = `mt-4 p-3 rounded-lg text-sm block`;
    statusBar.style.background = type === 'success' 
      ? 'var(--success-muted)' 
      : type === 'error' 
        ? 'var(--error-muted)' 
        : 'var(--info-muted)';
    statusBar.style.color = type === 'success' 
      ? 'var(--success)' 
      : type === 'error' 
        ? 'var(--error)' 
        : 'var(--info)';
    statusBar.style.border = `1px solid ${type === 'success' 
      ? 'rgba(74, 222, 128, 0.3)' 
      : type === 'error' 
        ? 'rgba(248, 113, 113, 0.3)' 
        : 'rgba(96, 165, 250, 0.3)'}`;
    statusBar.textContent = msg;
  }

  // Make it globally available
  (window as any).showStatus = showStatus;
</script>