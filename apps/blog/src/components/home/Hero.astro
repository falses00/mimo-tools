---
import HeroScene from '../visual/HeroScene';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<section class="hero-stage relative overflow-hidden">
  <div class="hero-ambient" aria-hidden="true"></div>
  <div class="absolute inset-0 -z-10">
    <HeroScene client:load />
  </div>

  <div class="container relative hero-content">
    <div class="max-w-4xl">
      {/* Badge */}
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-lg mb-8 glass-panel animate-pulse-glow">
        <span class="w-2 h-2 rounded-full" style="background: var(--gold);"></span>
        <span class="text-sm font-medium" style="color: var(--gold-soft);">Public engineering workbench</span>
      </div>

      {/* Title */}
      <h1 class="hero-title text-5xl sm:text-6xl lg:text-7xl font-bold tracking-normal mb-8">
        <span style="color: var(--text-primary);">MIMO</span>
        <span class="block mt-2 bg-clip-text text-transparent bg-gradient-to-r from-[var(--gold)] to-[var(--gold-soft)]">
          专业工具与作品展示台
        </span>
      </h1>

      {/* Description */}
      <p class="text-lg sm:text-xl leading-relaxed mb-12 max-w-2xl mx-auto" style="color: var(--text-secondary);">
        把旗舰项目、Quick Utilities、技术博客、API 部署和未来大型项目入口放在同一个可信的个人工作台里。
      </p>

      {/* CTA Buttons */}
      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href={`${baseWithSlash}projects`} class="btn-gold w-full sm:w-auto px-8 py-3 text-base">
          探索旗舰项目
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 inline">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a href={`${baseWithSlash}workbench`} class="btn-ghost w-full sm:w-auto px-8 py-3 text-base">
          打开工作台
        </a>
        <a href={`${baseWithSlash}tools`} class="btn-ghost w-full sm:w-auto px-8 py-3 text-base">
          浏览工具
        </a>
      </div>

      {/* Stats */}
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-16 pt-8 hero-metrics">
        <div class="glass-panel p-4 rounded-xl">
          <div class="text-3xl font-bold" style="color: var(--gold);">Live</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">GitHub Pages</div>
        </div>
        <div class="glass-panel p-4 rounded-xl">
          <div class="text-3xl font-bold" style="color: var(--gold);">7/7</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">API Verified</div>
        </div>
        <div class="glass-panel p-4 rounded-xl">
          <div class="text-3xl font-bold" style="color: var(--gold);">Ready</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">Render/Supabase</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-stage {
    min-height: calc(100vh - 4rem);
    padding: 7rem 0 4.5rem;
    display: flex;
    align-items: center;
    background:
      radial-gradient(circle at 8% 20%, rgba(62, 96, 105, 0.28), transparent 32rem),
      radial-gradient(circle at 88% 10%, rgba(212, 175, 55, 0.2), transparent 28rem),
      linear-gradient(135deg, rgba(12, 17, 24, 0.94), rgba(18, 24, 32, 0.86) 48%, rgba(23, 23, 24, 0.94));
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero-ambient {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
    background-size: 76px 76px;
    mask-image: linear-gradient(180deg, black, transparent 92%);
    pointer-events: none;
  }

  .hero-content {
    z-index: 1;
  }

  .hero-title {
    max-width: 760px;
    text-wrap: balance;
  }

  .hero-metrics {
    max-width: 820px;
    border-top: 1px solid var(--border-subtle);
  }

  :global(.hero-scene) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.92;
  }

  :global(.hero-scene canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .light .hero-stage {
    background:
      radial-gradient(circle at 8% 20%, rgba(93, 154, 169, 0.22), transparent 32rem),
      radial-gradient(circle at 88% 10%, rgba(184, 134, 11, 0.18), transparent 28rem),
      linear-gradient(135deg, rgba(243, 248, 250, 0.98), rgba(230, 238, 241, 0.96) 48%, rgba(246, 242, 232, 0.98));
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(2deg); }
  }
  
  .animate-float {
    animation: float 8s ease-in-out infinite;
  }
  
  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 20px var(--gold-glow); }
    50% { box-shadow: 0 0 40px var(--gold-glow-strong); }
  }
  
  .animate-pulse-glow {
    animation: pulse-glow 3s ease-in-out infinite;
  }
  
  @media (prefers-reduced-motion: reduce) {
    .animate-float, .animate-pulse-glow {
      animation: none;
    }
  }

  @media (max-width: 640px) {
    .hero-stage {
      min-height: auto;
      padding: 5rem 0 3rem;
    }

    .hero-title {
      font-size: 2.75rem;
      line-height: 1.08;
    }

    :global(.hero-scene) {
      opacity: 0.52;
      transform: translateX(18%);
    }
  }
</style>
