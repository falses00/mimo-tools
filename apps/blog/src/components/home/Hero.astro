---
---

<section class="relative overflow-hidden bg-background py-24 sm:py-32">
  <div class="absolute inset-0 -z-10 mx-0 max-w-none overflow-hidden">
    <div class="absolute left-1/2 top-0 ml-[-38rem] h-[28rem] w-[81.5rem] dark:[mask-image:linear-gradient(white,transparent)]">
      <div class="absolute inset-0 bg-gradient-to-r from-[#36b49f]/30 to-[#DBFF73]/30 opacity-40 [mask-image:radial-gradient(farthest-side_at_top,white,transparent)] dark:from-[#36b49f]/30 dark:to-[#DBFF73]/30 dark:opacity-20">
      </div>
    </div>
  </div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-6xl">
        MIMO
      </h1>
      <p class="mt-6 text-lg leading-8 text-muted-foreground">
        个人工具生态：包含多个实用工具、博客和导航站
      </p>
      <div class="mt-10 flex items-center justify-center gap-x-6">
        <a
          href="/tools"
          class="rounded-md bg-primary px-3.5 py-2.5 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          浏览工具
        </a>
        <a
          href="/blog"
          class="text-sm font-semibold leading-6 text-foreground"
        >
          阅读博客 <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>