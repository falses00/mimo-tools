---
import HeroScene from '../visual/HeroScene';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<section class="hero-stage relative overflow-hidden">
  <div class="container relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      {/* Left: Text Content */}
      <div class="flex flex-col gap-6">
        {/* Badge */}
        <div class="hero-pill inline-flex items-center self-start px-4 py-1.5 rounded-full">
          <span class="relative flex h-2 w-2 mr-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--gold)] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2" style="background: var(--gold);"></span>
          </span>
          <span class="text-xs font-bold uppercase tracking-widest font-mono" style="color: var(--text-muted);">MIMO Engineering</span>
        </div>

        {/* Title */}
        <h1 class="hero-title text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-tight">
          <div class="overflow-hidden">
            <span style="color: var(--text-primary);">MIMO</span>
          </div>
          <span class="animate-shine bg-[linear-gradient(110deg,var(--gold-deep),45%,var(--gold),55%,var(--gold-deep))] bg-[length:200%_100%] bg-clip-text text-transparent text-4xl md:text-5xl lg:text-6xl mt-2 font-black tracking-tighter drop-shadow-lg inline-block" style="--shine-duration:4s">
            专业工程工具生态
          </span>
        </h1>

        {/* Description */}
        <p class="text-lg leading-relaxed max-w-xl" style="color: var(--text-secondary);">
          6 个旗舰项目工作台、完整后端 API、RAG 检索系统、3D 暗金高级视觉。所有工具纯前端处理，数据不离开浏览器。
        </p>

        {/* Feature Points */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-2">
          <div class="hero-point flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" style="color: var(--gold);">
              <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
              <path d="m9 11 3 3L22 4"></path>
            </svg>
            Fullstack API with Render
          </div>
          <div class="hero-point flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" style="color: var(--gold);">
              <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
              <path d="m9 11 3 3L22 4"></path>
            </svg>
            Local RAG Retrieval
          </div>
          <div class="hero-point flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" style="color: var(--gold);">
              <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
              <path d="m9 11 3 3L22 4"></path>
            </svg>
            6 Flagship Workbenches
          </div>
          <div class="hero-point flex items-center gap-2 text-sm" style="color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0" style="color: var(--gold);">
              <path d="M21.801 10A10 10 0 1 1 17 3.335"></path>
              <path d="m9 11 3 3L22 4"></path>
            </svg>
            GitHub Pages + Render API
          </div>
        </div>

        {/* CTA Buttons */}
        <div class="flex flex-wrap gap-4 mt-4">
          <a href={`${baseWithSlash}projects`} class="hero-btn group btn-gold px-8 py-3 text-sm tracking-widest uppercase">
            探索项目
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a href={`${baseWithSlash}tools`} class="hero-btn btn-ghost px-8 py-3 text-sm tracking-widest uppercase">
            浏览工具
          </a>
        </div>
      </div>

      {/* Right: 3D Scene */}
      <div class="relative hidden lg:block">
        <div class="hero-visual">
          <HeroScene client:visible />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-stage {
    min-height: calc(100vh - 6rem);
    padding: 8rem 0 4rem;
    display: flex;
    align-items: center;
  }

  .hero-pill {
    background: rgba(11, 13, 18, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-title {
    text-wrap: balance;
  }

  .hero-visual {
    position: relative;
    width: 100%;
    height: 500px;
    border-radius: 1.5rem;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(11, 13, 18, 0.5);
    box-shadow: 
      0 0 50px rgba(0, 0, 0, 0.3),
      0 0 30px rgba(212, 175, 55, 0.05);
  }

  :global(.hero-visual canvas) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  @keyframes shine {
    0% { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  .animate-shine {
    animation: shine var(--shine-duration, 4s) linear infinite;
  }

  @media (max-width: 1024px) {
    .hero-stage {
      min-height: auto;
      padding: 6rem 0 3rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }
  }

  @media (max-width: 640px) {
    .hero-stage {
      padding: 5rem 0 2rem;
    }

    .hero-title {
      font-size: 2rem;
    }
  }
</style>