---
const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<section class="hero-stage relative overflow-hidden">
  <div class="container relative">
    <div class="hero-grid">
      {/* Left: Text Content */}
      <div class="hero-left">
        {/* Badge */}
        <div class="hero-pill inline-flex items-center self-start px-4 py-1.5 rounded-full mb-6">
          <span class="relative flex h-2 w-2 mr-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[var(--gold)] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2" style="background: var(--gold);"></span>
          </span>
          <span class="text-xs font-bold uppercase tracking-widest font-mono" style="color: var(--text-muted);">Fullstack Engineering</span>
        </div>

        {/* Title */}
        <h1 class="hero-title text-4xl md:text-5xl lg:text-6xl font-black leading-tight tracking-tight mb-6">
          <span style="color: var(--text-primary);">MIMO</span>
          <span class="block mt-2 animate-shine bg-[linear-gradient(110deg,var(--gold-deep),45%,var(--gold),55%,var(--gold-deep))] bg-[length:200%_100%] bg-clip-text text-transparent font-black tracking-tighter" style="--shine-duration:4s">
            全栈工程工具生态
          </span>
        </h1>

        {/* Description */}
        <p class="text-lg leading-relaxed mb-8" style="color: var(--text-secondary);">
          6 个旗舰项目工作台、Render 后端 API、本地 RAG 检索、数据工作台。前端精美，后端真实可用。
        </p>

        {/* Feature Points */}
        <div class="grid grid-cols-2 gap-3 mb-8">
          <div class="feature-point">
            <div class="feature-icon">⚡</div>
            <div class="feature-text">Render API</div>
          </div>
          <div class="feature-point">
            <div class="feature-icon">🔍</div>
            <div class="feature-text">RAG 检索</div>
          </div>
          <div class="feature-point">
            <div class="feature-icon">🛠️</div>
            <div class="feature-text">6 个工作台</div>
          </div>
          <div class="feature-point">
            <div class="feature-icon">🚀</div>
            <div class="feature-text">全栈部署</div>
          </div>
        </div>

        {/* CTA Buttons */}
        <div class="flex flex-wrap gap-4">
          <a href={`${baseWithSlash}projects`} class="btn-gold px-8 py-3 text-sm tracking-widest uppercase">
            探索项目
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 inline">
              <path d="M5 12h14" />
              <path d="m12 5 7 7-7 7" />
            </svg>
          </a>
          <a href={`${baseWithSlash}tools`} class="btn-ghost px-8 py-3 text-sm tracking-widest uppercase">
            浏览工具
          </a>
        </div>
      </div>

      {/* Right: Terminal Preview */}
      <div class="hero-right">
        <div class="terminal-preview">
          <div class="terminal-header">
            <div class="terminal-dots">
              <span class="dot dot-red"></span>
              <span class="dot dot-yellow"></span>
              <span class="dot dot-green"></span>
            </div>
            <div class="terminal-title">mimo-tools ~ api</div>
          </div>
          <div class="terminal-body">
            <div class="terminal-line">
              <span class="terminal-prompt">$</span>
              <span class="terminal-command">curl https://mimo-tools-api.onrender.com/api/health</span>
            </div>
            <div class="terminal-line terminal-output">
              <span class="terminal-success">{'{'}status: ok, version: 1.0.0{'}'}</span>
            </div>
            <div class="terminal-line">
              <span class="terminal-prompt">$</span>
              <span class="terminal-command">npm run verify:api</span>
            </div>
            <div class="terminal-line terminal-output">
              <span class="terminal-success">7/7 endpoints passed</span>
            </div>
            <div class="terminal-line">
              <span class="terminal-prompt">$</span>
              <span class="terminal-command">npm run test:links</span>
            </div>
            <div class="terminal-line terminal-output">
              <span class="terminal-success">All links correctly use /mimo-tools/</span>
            </div>
            <div class="terminal-line">
              <span class="terminal-prompt">$</span>
              <span class="terminal-cursor">_</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-stage {
    min-height: calc(100vh - 6rem);
    padding: 8rem 0 4rem;
    display: flex;
    align-items: center;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .hero-left {
    max-width: 560px;
  }

  .hero-right {
    display: flex;
    justify-content: center;
  }

  .hero-pill {
    background: rgba(11, 13, 18, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-title {
    text-wrap: balance;
  }

  .feature-point {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: all 0.2s ease;
  }

  .feature-point:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(212, 175, 55, 0.2);
  }

  .feature-icon {
    font-size: 1.25rem;
  }

  .feature-text {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Terminal Preview */
  .terminal-preview {
    width: 100%;
    max-width: 520px;
    border-radius: 1rem;
    overflow: hidden;
    background: rgba(11, 13, 18, 0.95);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 
      0 25px 50px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 0 40px rgba(212, 175, 55, 0.08);
    transform: perspective(1000px) rotateY(-5deg) rotateX(2deg);
    transition: transform 0.3s ease;
  }

  .terminal-preview:hover {
    transform: perspective(1000px) rotateY(0deg) rotateX(0deg);
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
  }

  .terminal-dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-yellow { background: #febc2e; }
  .dot-green { background: #28c840; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 0.75rem;
    font-family: monospace;
    color: rgba(255, 255, 255, 0.3);
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    line-height: 1.8;
  }

  .terminal-line {
    margin-bottom: 0.5rem;
  }

  .terminal-prompt {
    color: var(--gold);
    margin-right: 0.75rem;
  }

  .terminal-command {
    color: rgba(255, 255, 255, 0.8);
  }

  .terminal-output {
    padding-left: 1.5rem;
  }

  .terminal-success {
    color: #4ade80;
  }

  .terminal-cursor {
    color: var(--gold);
    animation: blink 1s infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes shine {
    0% { background-position: 200% center; }
    100% { background-position: -200% center; }
  }

  .animate-shine {
    animation: shine var(--shine-duration, 4s) linear infinite;
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .hero-left {
      max-width: 100%;
      text-align: center;
    }

    .hero-right {
      justify-content: center;
    }

    .terminal-preview {
      transform: none;
      max-width: 480px;
    }

    .terminal-preview:hover {
      transform: none;
    }
  }

  @media (max-width: 768px) {
    .hero-stage {
      min-height: auto;
      padding: 6rem 0 3rem;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .terminal-preview {
      max-width: 100%;
    }
  }
</style>