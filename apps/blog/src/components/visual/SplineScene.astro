---
interface Props {
  sceneKey: string;
  sceneUrl?: string;
  title?: string;
  height?: string;
}

const { sceneKey, sceneUrl = '', title = '', height = '400px' } = Astro.props;
const hasScene = !!sceneUrl;
---

<div
  class="hero-visual-wrapper"
  style={`height: ${height};`}
  data-scene-wrapper={hasScene ? 'true' : 'false'}
  data-scene-url={sceneUrl}
  data-scene-title={title || sceneKey}
>
  {hasScene && <div class="scene-container" aria-hidden="true"></div>}
  <div class="fallback-visual">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
    <div class="grid-bg"></div>
    <div class="content">
      <div class="icon" aria-hidden="true">✨</div>
      <div class="label">{title || sceneKey}</div>
    </div>
  </div>
</div>

<style>
  .hero-visual-wrapper {
    position: relative;
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .scene-container {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 240ms ease;
  }

  .hero-visual-wrapper.is-loaded .scene-container {
    opacity: 1;
  }
  
  .scene-container iframe {
    width: 100%;
    height: 100%;
    border: none;
    pointer-events: none;
  }
  
  .fallback-visual {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0b0d12 0%, #11151d 50%, #171c26 100%);
  }

  .hero-visual-wrapper.is-loaded .fallback-visual {
    opacity: 0;
    pointer-events: none;
  }
  
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    animation: float 8s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(212,175,55,0.3), transparent);
    top: 20%;
    left: 20%;
  }
  
  .orb-2 {
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(212,175,55,0.2), transparent);
    top: 60%;
    right: 25%;
    animation-delay: -2s;
  }
  
  .orb-3 {
    width: 60px;
    height: 60px;
    background: radial-gradient(circle, rgba(212,175,55,0.15), transparent);
    bottom: 30%;
    left: 40%;
    animation-delay: -4s;
  }
  
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(212,175,55,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }
  
  .content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  
  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  
  .label {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }

  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .scene-container {
      display: none;
    }
    .orb {
      animation: none;
    }
  }
</style>

<script>
  const mountScenes = () => {
    const isMobile = window.matchMedia('(max-width: 767px)').matches;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (isMobile || reduceMotion) return;

    document.querySelectorAll('[data-scene-wrapper="true"]').forEach((wrapper) => {
      if (wrapper.dataset.splineMounted === 'true') return;

      const sceneUrl = wrapper.dataset.sceneUrl;
      const sceneTitle = wrapper.dataset.sceneTitle || '';
      const container = wrapper.querySelector('.scene-container');
      if (!sceneUrl || !container) return;

      wrapper.dataset.splineMounted = 'true';

      const iframe = document.createElement('iframe');
      iframe.src = sceneUrl;
      iframe.title = sceneTitle;
      iframe.loading = 'lazy';
      iframe.allow = 'autoplay; fullscreen';
      iframe.referrerPolicy = 'strict-origin-when-cross-origin';
      iframe.style.pointerEvents = 'none';
      iframe.setAttribute('frameborder', '0');
      iframe.setAttribute('aria-hidden', 'true');

      iframe.addEventListener('load', () => {
        wrapper.classList.add('is-loaded');
      });

      iframe.addEventListener('error', () => {
        wrapper.classList.remove('is-loaded');
        container.replaceChildren();
      });

      container.appendChild(iframe);
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', mountScenes, { once: true });
  } else {
    mountScenes();
  }
</script>