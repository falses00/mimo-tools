---
interface Props {
  sceneKey: string;
  sceneUrl?: string;
  title?: string;
  height?: string;
}

const { sceneKey, sceneUrl = '', title = '', height = '400px' } = Astro.props;
const hasScene = !!sceneUrl;
---

<div class="spline-wrapper" style={`height: ${height};`}>
  {hasScene ? (
    <div class="spline-container">
      <iframe 
        src={sceneUrl}
        frameborder="0"
        width="100%"
        height="100%"
        allow="autoplay; fullscreen"
        loading="lazy"
        title={title || sceneKey}
      ></iframe>
    </div>
  ) : (
    <div class="spline-fallback">
      <div class="fallback-visual">
        <div class="orb orb-1"></div>
        <div class="orb orb-2"></div>
        <div class="orb orb-3"></div>
        <div class="grid-bg"></div>
        <div class="content">
          <div class="icon">✨</div>
          <div class="label">{title || sceneKey}</div>
          <div class="hint">3D 视觉效果</div>
        </div>
      </div>
    </div>
  )}
</div>

<style>
  .spline-wrapper {
    position: relative;
    width: 100%;
    border-radius: 1rem;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .spline-container {
    width: 100%;
    height: 100%;
  }
  
  .spline-container iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  
  .spline-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #0b0d12 0%, #11151d 50%, #171c26 100%);
  }
  
  .fallback-visual {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(40px);
    animation: float 8s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 120px;
    height: 120px;
    background: radial-gradient(circle, rgba(212,175,55,0.3), transparent);
    top: 20%;
    left: 20%;
  }
  
  .orb-2 {
    width: 80px;
    height: 80px;
    background: radial-gradient(circle, rgba(212,175,55,0.2), transparent);
    top: 60%;
    right: 25%;
    animation-delay: -2s;
  }
  
  .orb-3 {
    width: 60px;
    height: 60px;
    background: radial-gradient(circle, rgba(212,175,55,0.15), transparent);
    bottom: 30%;
    left: 40%;
    animation-delay: -4s;
  }
  
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(212,175,55,0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212,175,55,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.5;
  }
  
  .content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  
  .icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }
  
  .label {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  
  .hint {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }
</style>