---
interface Props {
  sceneKey: string;
  sceneUrl?: string;
  title?: string;
  fallback?: string;
  height?: string;
  mode?: 'viewer' | 'iframe';
}

const { 
  sceneKey, 
  sceneUrl = '', 
  title = '', 
  fallback = 'default',
  height = '400px',
  mode = 'viewer'
} = Astro.props;

const hasScene = !!sceneUrl;
---

<div 
  class="spline-container" 
  data-scene-key={sceneKey}
  data-scene-url={sceneUrl}
  data-fallback={fallback}
  style={`height: ${height};`}
>
  {hasScene ? (
    <div class="spline-viewer-wrapper">
      <spline-viewer 
        url={sceneUrl}
        loading-anim-type="spinner-big-dark"
        style="width: 100%; height: 100%;"
      ></spline-viewer>
    </div>
  ) : (
    <div class="spline-fallback" data-fallback-type={fallback}>
      <div class="fallback-content">
        <div class="fallback-orb"></div>
        <div class="fallback-grid"></div>
        <div class="fallback-text">{title || sceneKey}</div>
      </div>
    </div>
  )}
</div>

<style>
  .spline-container {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .spline-viewer-wrapper {
    width: 100%;
    height: 100%;
  }
  
  .spline-fallback {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  
  .fallback-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  
  .fallback-orb {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--gold-glow) 0%, transparent 70%);
    animation: orb-pulse 4s ease-in-out infinite;
  }
  
  .fallback-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(var(--border-subtle) 1px, transparent 1px),
      linear-gradient(90deg, var(--border-subtle) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.3;
  }
  
  .fallback-text {
    position: relative;
    z-index: 2;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    text-shadow: 0 0 20px var(--gold-glow);
  }
  
  @keyframes orb-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.5; }
    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.8; }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .fallback-orb {
      animation: none;
    }
  }
</style>

<script>
  // Load spline-viewer script if needed
  const containers = document.querySelectorAll('.spline-container');
  
  containers.forEach(container => {
    const sceneUrl = container.getAttribute('data-scene-url');
    if (sceneUrl) {
      // Load spline-viewer web component
      if (!document.querySelector('script[src*="spline-viewer"]')) {
        const script = document.createElement('script');
        script.type = 'module';
        script.src = 'https://unpkg.com/@splinetool/viewer/build/spline-viewer.js';
        document.head.appendChild(script);
      }
    }
  });
</script>