---
// Subtle architectural background for the product showcase.
---

<div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none" aria-hidden="true">
  <div class="absolute inset-0 grid-bg opacity-25"></div>
  <div class="absolute inset-0 blueprint-lines"></div>
  <div class="absolute inset-0 vignette"></div>
</div>

<style>
  .blueprint-lines {
    background-image:
      linear-gradient(115deg, transparent 0 36%, rgba(212, 175, 55, 0.08) 36.2%, transparent 36.8% 100%),
      linear-gradient(65deg, transparent 0 64%, rgba(96, 165, 250, 0.06) 64.2%, transparent 64.8% 100%);
    background-size: 760px 520px, 680px 460px;
    background-position: 10% 0, 90% 12%;
  }

  .vignette {
    background:
      radial-gradient(circle at 16% 10%, rgba(106, 166, 184, 0.14), transparent 24rem),
      radial-gradient(circle at 82% 18%, rgba(214, 178, 74, 0.12), transparent 26rem),
      linear-gradient(180deg, rgba(13, 17, 24, 0.12), var(--bg-page) 96%),
      linear-gradient(90deg, var(--bg-page), transparent 22%, transparent 78%, var(--bg-page));
  }

  .light .vignette {
    background:
      radial-gradient(circle at 16% 10%, rgba(106, 166, 184, 0.14), transparent 24rem),
      radial-gradient(circle at 82% 18%, rgba(184, 134, 11, 0.12), transparent 26rem),
      linear-gradient(180deg, rgba(255, 253, 248, 0.1), var(--bg-page) 96%),
      linear-gradient(90deg, var(--bg-page), transparent 22%, transparent 78%, var(--bg-page));
  }
</style>
