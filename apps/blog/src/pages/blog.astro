---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="博客 - MIMO">
  <main class="min-h-screen bg-background">
    <div class="container mx-auto px-4 py-12">
      <div class="text-center mb-12">
        <h1 class="text-4xl font-bold mb-4">博客</h1>
        <p class="text-muted-foreground text-lg">技术文章与经验分享</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedPosts.map(post => (
          <a href={`/blog/${post.slug}`} class="group block p-6 rounded-xl border border-border hover:border-primary hover:shadow-lg transition-all duration-200">
            <h2 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">{post.data.title}</h2>
            <p class="text-muted-foreground text-sm mb-4">{post.data.description}</p>
            <div class="flex flex-wrap gap-1">
              {post.data.tags.map(tag => (
                <span class="text-xs bg-secondary/50 px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
            <time class="text-xs text-muted-foreground mt-2 block">
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>
