---
import Layout from '../layouts/Layout.astro';
import { portfolioProjects, projectCategories } from '../data/portfolio';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<Layout title="项目展示 - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">项目展示</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          🚀 独立项目
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          每个旗舰项目都是独立完整产品，拥有自己的前端、后端、数据库和测试
        </p>
      </div>

      {/* Category Filter */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button class="btn btn-primary category-btn" data-category="all">全部项目</button>
        {projectCategories.map(cat => (
          <button class="btn btn-secondary category-btn" data-category={cat.id}>
            {cat.icon} {cat.name}
          </button>
        ))}
      </div>

      {/* Projects Grid */}
      <div id="projects-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {portfolioProjects.map(project => (
          <div
            class="group block rounded-xl overflow-hidden transition-all duration-300 project-card"
            style="background: var(--bg-card); border: 1px solid var(--border-subtle);"
            data-category={project.category}
          >
            <div class="p-8">
              {/* Header */}
              <div class="flex items-start gap-4 mb-6">
                <div class="flex items-center justify-center w-16 h-16 rounded-2xl flex-shrink-0" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
                  <span class="text-3xl">{project.icon}</span>
                </div>
                <div>
                  <h2 class="text-2xl font-bold mb-1" style="color: var(--text-primary);">
                    {project.name}
                  </h2>
                  <p class="text-sm" style="color: var(--gold-soft);">{project.tagline}</p>
                </div>
              </div>

              {/* Description */}
              <p class="mb-6" style="color: var(--text-muted);">
                {project.description}
              </p>

              {/* Tech Stack */}
              <div class="mb-6">
                <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">技术栈</h3>
                <div class="flex flex-wrap gap-2">
                  {project.techStack.map(tech => (
                    <span class="badge text-xs" style="background: var(--bg-elevated); border-color: var(--border-subtle); color: var(--text-muted);">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              {/* Highlights */}
              <div class="mb-6">
                <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">核心亮点</h3>
                <div class="flex flex-wrap gap-2">
                  {project.highlights.map(highlight => (
                    <span class="badge badge-gold text-xs">{highlight}</span>
                  ))}
                </div>
              </div>

              {/* Links */}
              <div class="flex flex-wrap gap-3">
                {project.githubUrl && (
                  <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="btn btn-ghost text-xs">
                    GitHub 仓库
                  </a>
                )}
                {project.demoUrl && (
                  <a href={project.demoUrl} class="btn btn-ghost text-xs">
                    在线 Demo
                  </a>
                )}
                {project.docsUrl && (
                  <a href={project.docsUrl} class="btn btn-ghost text-xs">
                    文档
                  </a>
                )}
              </div>

              {/* Status */}
              <div class="mt-4 pt-4" style="border-top: 1px solid var(--border-subtle);">
                <span class:list={[
                  'badge text-xs',
                  project.status === 'production' ? 'badge-success' : 
                  project.status === 'development' ? 'badge-gold' : 'badge'
                ]}>
                  {project.status === 'production' ? '已上线' : 
                   project.status === 'development' ? '开发中' : '计划中'}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Stats */}
      <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">6</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">独立项目</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">5</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">已上线</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">10+</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">API Endpoints</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">100%</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">开源</div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const projectCards = document.querySelectorAll('.project-card');

  let currentCategory = 'all';

  function filterProjects() {
    projectCards.forEach(card => {
      const category = card.getAttribute('data-category') || '';
      if (currentCategory === 'all' || category === currentCategory) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  }

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      currentCategory = category;

      categoryBtns.forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-secondary');
      });
      btn.classList.remove('btn-secondary');
      btn.classList.add('btn-primary');

      filterProjects();
    });
  });
</script>