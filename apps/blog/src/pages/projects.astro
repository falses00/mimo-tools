---
import Layout from '../layouts/Layout.astro';
import { projects, projectCategories } from '../data/projects';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<Layout title="旗舰项目 - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">旗舰项目</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4" style="color: var(--text-primary);">
          🚀 Flagship Projects
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          真正有技术含量的工程项目，展示 AI、数据、后端、前端全栈能力
        </p>
      </div>

      {/* Category Filter */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button class="btn btn-primary category-btn" data-category="all">全部项目</button>
        {projectCategories.map(cat => (
          <button class="btn btn-secondary category-btn" data-category={cat.id}>
            {cat.icon} {cat.name}
          </button>
        ))}
      </div>

      {/* Projects Grid */}
      <div id="projects-grid" class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {projects.map(project => (
          <a
            href={`${baseWithSlash}projects/${project.id}`}
            class="group block rounded-xl overflow-hidden transition-all duration-300 project-card"
            style="background: var(--bg-card); border: 1px solid var(--border-subtle);"
            data-category={project.category}
          >
            <div class="p-8">
              {/* Header */}
              <div class="flex items-start gap-4 mb-6">
                <div class="flex items-center justify-center w-16 h-16 rounded-2xl flex-shrink-0" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
                  <span class="text-3xl">{project.icon}</span>
                </div>
                <div>
                  <h2 class="text-2xl font-bold mb-2 transition-colors duration-200 group-hover:text-[var(--gold-primary)]" style="color: var(--text-primary);">
                    {project.name}
                  </h2>
                  <p class="text-sm" style="color: var(--text-muted);">
                    {project.description}
                  </p>
                </div>
              </div>

              {/* Description */}
              <p class="mb-6 leading-relaxed" style="color: var(--text-secondary);">
                {project.longDescription}
              </p>

              {/* Capabilities */}
              <div class="mb-6">
                <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">核心能力</h3>
                <div class="flex flex-wrap gap-2">
                  {project.capabilities.map(cap => (
                    <span class="badge badge-gold text-xs">{cap}</span>
                  ))}
                </div>
              </div>

              {/* Tech Stack */}
              <div class="mb-6">
                <h3 class="text-sm font-semibold mb-3" style="color: var(--text-primary);">技术栈</h3>
                <div class="flex flex-wrap gap-2">
                  {project.techStack.map(tech => (
                    <span class="badge text-xs" style="background: var(--bg-elevated); border-color: var(--border-subtle); color: var(--text-muted);">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>

              {/* Features */}
              <div class="flex flex-wrap gap-4 text-xs" style="color: var(--text-muted);">
                {project.hasBackend && (
                  <span class="flex items-center gap-1">
                    <span style="color: var(--success);">●</span> 后端 API
                  </span>
                )}
                {project.hasDatabase && (
                  <span class="flex items-center gap-1">
                    <span style="color: var(--info);">●</span> 数据库
                  </span>
                )}
                {project.hasRAG && (
                  <span class="flex items-center gap-1">
                    <span style="color: var(--warning);">●</span> RAG 检索
                  </span>
                )}
              </div>

              {/* Arrow */}
              <div class="mt-6 flex items-center gap-2 text-sm font-medium opacity-0 group-hover:opacity-100 transition-all duration-200" style="color: var(--gold-primary);">
                <span>探索项目</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>

      {/* Stats */}
      <div class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">5</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">旗舰项目</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">3</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">后端 API</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">1</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">RAG 检索</div>
        </div>
        <div class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);">100%</div>
          <div class="text-sm mt-1" style="color: var(--text-muted);">真实可用</div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const projectCards = document.querySelectorAll('.project-card');

  let currentCategory = 'all';

  function filterProjects() {
    projectCards.forEach(card => {
      const category = card.getAttribute('data-category') || '';
      if (currentCategory === 'all' || category === currentCategory) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  }

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      currentCategory = category;

      categoryBtns.forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-secondary');
      });
      btn.classList.remove('btn-secondary');
      btn.classList.add('btn-primary');

      filterProjects();
    });
  });
</script>