---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;

const toolStudios = [
  { name: 'Format Studio', desc: 'JSON/YAML/TOML 格式化与验证', icon: '📝', href: '/tools/json-formatter' },
  { name: 'Markdown Studio', desc: 'Markdown 预览、TOC、统计', icon: '✍️', href: '/tools/markdown-previewer' },
  { name: 'Regex Studio', desc: '正则表达式测试与模板', icon: '🔤', href: '/tools/regex-tester' },
  { name: 'Encode Studio', desc: 'URL/Base64/HTML 编码解码', icon: '🔗', href: '/tools/url-encoder' },
  { name: 'Time & ID Studio', desc: '时间戳、Cron、UUID 生成', icon: '⏱️', href: '/tools/timestamp-converter' },
  { name: 'Design Utility', desc: '颜色、对比度、Token 预览', icon: '🎨', href: '/tools/color-palette' },
];
---

<Layout title="工具集合 - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">工具集合</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          🛠️ 工具集合
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          6 个组合工具套件，覆盖格式化、编码、时间、设计等常用场景
        </p>
      </div>

      {/* Tool Studios */}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        {toolStudios.map(tool => (
          <a href={`${baseWithSlash}${tool.href.substring(1)}`} class="tool-card">
            <div class="tool-icon">{tool.icon}</div>
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.desc}</p>
            <span class="badge badge-gold text-xs">MIMO Utilities</span>
          </a>
        ))}
      </div>

      {/* MIMO Utilities Info */}
      <div class="info-card">
        <h3 class="info-title">📦 MIMO Utilities</h3>
        <p class="info-text">
          这些工具正在迁移到独立项目 <strong>mimo-utilities</strong>。
          迁移完成后，个人站将只展示入口，工具功能将在独立项目中提供。
        </p>
        <a href="https://github.com/falses00/mimo-utilities" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
          GitHub 仓库
        </a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .tool-card { display: block; padding: 1.5rem; border-radius: 1rem; background: var(--bg-card); border: 1px solid var(--border-subtle); transition: all 0.2s; }
  .tool-card:hover { border-color: var(--gold-border); transform: translateY(-2px); box-shadow: var(--shadow-gold); }
  .tool-icon { font-size: 2rem; margin-bottom: 1rem; }
  .tool-name { font-size: 1.25rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
  .tool-desc { font-size: 0.875rem; color: var(--text-muted); margin-bottom: 1rem; }
  .info-card { padding: 2rem; border-radius: 1rem; background: var(--bg-card); border: 1px solid var(--gold-border); text-align: center; }
  .info-title { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1rem; }
  .info-text { color: var(--text-secondary); margin-bottom: 1.5rem; max-width: 600px; margin-left: auto; margin-right: auto; }
</style>