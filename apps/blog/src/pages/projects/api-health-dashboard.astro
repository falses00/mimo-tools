---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="API Health Dashboard - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="mb-8">
        <a href="/projects" class="inline-flex items-center gap-2 text-sm mb-4 transition-colors duration-200" style="color: var(--text-muted);">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          返回旗舰项目
        </a>
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-16 h-16 rounded-2xl" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
            <span class="text-3xl">💓</span>
          </div>
          <div>
            <h1 class="text-3xl font-bold" style="color: var(--text-primary);">API Health Dashboard</h1>
            <p style="color: var(--text-muted);">API 端点健康检查与状态监控</p>
          </div>
        </div>
      </div>

      {/* Add Endpoint */}
      <div class="p-6 rounded-xl mb-8" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
        <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">➕ 添加端点</h3>
        <div class="flex flex-col sm:flex-row gap-4">
          <input
            type="text"
            id="input-url"
            class="input flex-1"
            placeholder="输入 API URL，例如: https://api.github.com"
          />
          <input
            type="text"
            id="input-name"
            class="input w-full sm:w-48"
            placeholder="名称 (可选)"
          />
          <button id="btn-add" class="btn btn-primary">
            添加
          </button>
        </div>
        <div class="mt-4 flex flex-wrap gap-2">
          <button class="btn btn-ghost text-xs" onclick="addSampleEndpoints()">加载示例端点</button>
          <button class="btn btn-ghost text-xs" onclick="runAllChecks()">运行所有检查</button>
          <button class="btn btn-ghost text-xs" onclick="exportResults()">导出 JSON</button>
        </div>
      </div>

      {/* Stats */}
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
        <div class="p-4 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--gold-primary);" id="stat-total">0</div>
          <div class="text-xs mt-1" style="color: var(--text-muted);">总端点</div>
        </div>
        <div class="p-4 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--success);" id="stat-ok">0</div>
          <div class="text-xs mt-1" style="color: var(--text-muted);">正常</div>
        </div>
        <div class="p-4 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--warning);" id="stat-warning">0</div>
          <div class="text-xs mt-1" style="color: var(--text-muted);">警告</div>
        </div>
        <div class="p-4 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <div class="text-3xl font-bold" style="color: var(--error);" id="stat-down">0</div>
          <div class="text-xs mt-1" style="color: var(--text-muted);">宕机</div>
        </div>
      </div>

      {/* Endpoints List */}
      <div id="endpoints-list" class="space-y-4">
        {/* Endpoints will be added here */}
      </div>

      {/* Empty State */}
      <div id="empty-state" class="p-12 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
        <div class="text-6xl mb-4">💓</div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--text-primary);">添加 API 端点</h3>
        <p style="color: var(--text-muted);">输入 URL 开始监控 API 健康状态</p>
      </div>

      {/* Status Bar */}
      <div id="status-bar" class="mt-6 p-3 rounded-lg text-sm hidden"></div>
    </div>
  </div>
</Layout>

<script>
  interface Endpoint {
    id: string;
    url: string;
    name: string;
    status?: 'ok' | 'warning' | 'down';
    statusCode?: number;
    latency?: number;
    lastCheck?: string;
  }

  let endpoints: Endpoint[] = [];
  const endpointsList = document.getElementById('endpoints-list') as HTMLDivElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const statusBar = document.getElementById('status-bar') as HTMLDivElement;

  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    statusBar.className = 'mt-6 p-3 rounded-lg text-sm block';
    statusBar.style.background = type === 'success' ? 'var(--success-muted)' : type === 'error' ? 'var(--error-muted)' : 'var(--info-muted)';
    statusBar.style.color = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--error)' : 'var(--info)';
    statusBar.textContent = msg;
  }

  function updateStats() {
    const total = endpoints.length;
    const ok = endpoints.filter(e => e.status === 'ok').length;
    const warning = endpoints.filter(e => e.status === 'warning').length;
    const down = endpoints.filter(e => e.status === 'down').length;
    
    document.getElementById('stat-total')!.textContent = total.toString();
    document.getElementById('stat-ok')!.textContent = ok.toString();
    document.getElementById('stat-warning')!.textContent = warning.toString();
    document.getElementById('stat-down')!.textContent = down.toString();
  }

  function renderEndpoints() {
    if (endpoints.length === 0) {
      emptyState.classList.remove('hidden');
      endpointsList.innerHTML = '';
    } else {
      emptyState.classList.add('hidden');
      endpointsList.innerHTML = endpoints.map(ep => `
        <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid ${ep.status === 'ok' ? 'var(--success-muted)' : ep.status === 'warning' ? 'var(--warning-muted)' : ep.status === 'down' ? 'var(--error-muted)' : 'var(--border-subtle)'};">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h4 class="font-semibold" style="color: var(--text-primary);">${ep.name}</h4>
              <p class="text-sm font-mono" style="color: var(--text-muted);">${ep.url}</p>
            </div>
            <div class="flex items-center gap-2">
              <span class="badge ${ep.status === 'ok' ? 'badge-success' : ep.status === 'warning' ? 'badge-error' : ep.status === 'down' ? 'badge-error' : ''} text-xs">
                ${ep.status || '未检查'}
              </span>
              <button class="btn btn-ghost text-xs" onclick="checkEndpoint('${ep.id}')">检查</button>
              <button class="btn btn-ghost text-xs" style="color: var(--error);" onclick="removeEndpoint('${ep.id}')">删除</button>
            </div>
          </div>
          ${ep.statusCode ? `
            <div class="flex gap-6 text-sm" style="color: var(--text-secondary);">
              <span>状态码: <strong>${ep.statusCode}</strong></span>
              <span>延迟: <strong>${ep.latency}ms</strong></span>
              <span>检查时间: <strong>${ep.lastCheck}</strong></span>
            </div>
          ` : ''}
        </div>
      `).join('');
    }
    updateStats();
  }

  function addEndpoint(url: string, name?: string) {
    if (!url) {
      showStatus('请输入 URL', 'error');
      return;
    }
    
    // Validate URL
    try {
      new URL(url);
    } catch {
      showStatus('请输入有效的 URL', 'error');
      return;
    }
    
    const endpoint: Endpoint = {
      id: Date.now().toString(),
      url,
      name: name || new URL(url).hostname,
    };
    
    endpoints.push(endpoint);
    renderEndpoints();
    saveEndpoints();
    showStatus('端点已添加', 'success');
  }

  function removeEndpoint(id: string) {
    endpoints = endpoints.filter(ep => ep.id !== id);
    renderEndpoints();
    saveEndpoints();
  }

  async function checkEndpoint(id: string) {
    const endpoint = endpoints.find(ep => ep.id === id);
    if (!endpoint) return;
    
    showStatus(`检查 ${endpoint.name}...`, 'info');
    
    // Simulate check
    await new Promise(resolve => setTimeout(resolve, 500 + Math.random() * 1000));
    
    // Mock results
    const statusCode = Math.random() > 0.2 ? 200 : Math.random() > 0.5 ? 404 : 500;
    const latency = Math.floor(Math.random() * 500) + 50;
    
    endpoint.statusCode = statusCode;
    endpoint.latency = latency;
    endpoint.lastCheck = new Date().toLocaleTimeString('zh-CN');
    
    if (statusCode >= 200 && statusCode < 300) {
      endpoint.status = latency > 300 ? 'warning' : 'ok';
    } else if (statusCode >= 400 && statusCode < 500) {
      endpoint.status = 'warning';
    } else {
      endpoint.status = 'down';
    }
    
    renderEndpoints();
    saveEndpoints();
    showStatus(`${endpoint.name}: ${statusCode} (${latency}ms)`, endpoint.status === 'ok' ? 'success' : 'error');
  }

  async function runAllChecks() {
    showStatus('运行所有检查...', 'info');
    for (const ep of endpoints) {
      await checkEndpoint(ep.id);
    }
    showStatus('所有检查完成', 'success');
  }

  function addSampleEndpoints() {
    const samples = [
      { url: 'https://api.github.com', name: 'GitHub API' },
      { url: 'https://httpbin.org/get', name: 'HTTPBin' },
      { url: 'https://jsonplaceholder.typicode.com/posts', name: 'JSONPlaceholder' },
    ];
    
    samples.forEach(s => addEndpoint(s.url, s.name));
  }

  function exportResults() {
    const data = JSON.stringify(endpoints, null, 2);
    const blob = new Blob([data], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'api-health-report.json';
    a.click();
    URL.revokeObjectURL(url);
    showStatus('已导出 JSON', 'success');
  }

  function saveEndpoints() {
    localStorage.setItem('apiEndpoints', JSON.stringify(endpoints));
  }

  function loadEndpoints() {
    const saved = localStorage.getItem('apiEndpoints');
    if (saved) {
      try {
        endpoints = JSON.parse(saved);
        renderEndpoints();
      } catch (e) {
        // Ignore
      }
    }
  }

  // Event listeners
  document.getElementById('btn-add')?.addEventListener('click', () => {
    const url = (document.getElementById('input-url') as HTMLInputElement).value.trim();
    const name = (document.getElementById('input-name') as HTMLInputElement).value.trim();
    addEndpoint(url, name);
    (document.getElementById('input-url') as HTMLInputElement).value = '';
    (document.getElementById('input-name') as HTMLInputElement).value = '';
  });

  // Make functions globally available
  (window as any).addSampleEndpoints = addSampleEndpoints;
  (window as any).runAllChecks = runAllChecks;
  (window as any).exportResults = exportResults;
  (window as any).checkEndpoint = checkEndpoint;
  (window as any).removeEndpoint = removeEndpoint;

  // Load saved endpoints
  loadEndpoints();
</script>