---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? '';
---

<Layout title="RepoPilot GitHub 热榜发现、安全审查与本地部署管家 - MIMO" description="发现热门仓库、审查风险、生成本地部署计划。">
  <div class="repopilot-app" data-api-base-url={apiBaseUrl}>
    {/* Hero */}
    <section class="rp-hero">
      <div class="container">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <span>GitHub 热榜发现、安全审查与本地部署管家</span>
        </div>
        <h1 class="hero-title">RepoPilot</h1>
        <p class="hero-subtitle">
          发现热门仓库、审查风险、生成本地部署计划。一站式解决找项目难、评估难、部署难。
        </p>
      </div>
    </section>

    {/* Workbench */}
    <section class="rp-workbench">
      <div class="container">
        <div class="workbench-grid">
          {/* Left: Controls */}
          <div class="workbench-left">
            {/* 新手引导 */}
            <div class="guide-card">
              <h3 class="guide-title">💡 新手引导</h3>
              <p class="guide-text">1. 浏览热门仓库或输入仓库地址</p>
              <p class="guide-text">2. 点击安全审查</p>
              <p class="guide-text">3. 生成部署计划</p>
              <button class="btn-use-example" id="btn-load-trending">加载热门仓库</button>
            </div>

            {/* 仓库输入 */}
            <div class="input-card">
              <h3 class="input-title">🔍 仓库地址</h3>
              <input id="input-repo" class="rp-input" placeholder="owner/repo，例如: falses00/mimo-tools" value="falses00/mimo-tools" />
              <div class="input-actions">
                <button class="btn-analyze" id="btn-audit">🛡️ 安全审查</button>
                <button class="btn-analyze btn-secondary" id="btn-deploy">📦 生成部署计划</button>
              </div>
            </div>

            {/* 热门仓库列表 */}
            <div class="repos-card">
              <h3 class="repos-title">🔥 热门仓库</h3>
              <div id="repos-list" class="repos-list">
                <p class="repos-empty">点击"加载热门仓库"获取</p>
              </div>
            </div>
          </div>

          {/* Right: Results */}
          <div class="workbench-right">
            {/* Mode Badge */}
            <div class="mode-badge-container">
              <span id="mode-badge" class="mode-badge">{apiBaseUrl ? 'API 模式' : '本地模式'}</span>
            </div>

            {/* 空状态 */}
            <div id="empty-state" class="empty-state">
              <div class="empty-icon">🔍</div>
              <h3 class="empty-title">开始探索</h3>
              <p class="empty-text">输入仓库地址或加载热门仓库，然后进行安全审查或生成部署计划</p>
            </div>

            {/* 安全审查结果 */}
            <div id="audit-section" class="result-section hidden">
              <h3 class="section-title">🛡️ 安全审查报告</h3>
              <div class="score-display">
                <div id="risk-score" class="score-value">0</div>
                <div class="score-label">风险分数</div>
              </div>
              <div id="findings-list" class="findings-list"></div>
              <div id="recommended-action" class="recommended-action"></div>
            </div>

            {/* 部署计划 */}
            <div id="deploy-section" class="result-section hidden">
              <h3 class="section-title">📦 部署计划</h3>
              <div id="deploy-info" class="deploy-info"></div>
            </div>

            {/* FAQ */}
            <div class="faq-section">
              <h3 class="faq-title">❓ 常见问题</h3>
              <div class="faq-list">
                <div class="faq-item">
                  <div class="faq-question">安全审查检查什么？</div>
                  <div class="faq-answer">检查 package.json scripts、Dockerfile、GitHub Actions 中的危险命令。</div>
                </div>
                <div class="faq-item">
                  <div class="faq-question">部署计划包含什么？</div>
                  <div class="faq-answer">clone 命令、安装命令、启动命令、需要的环境变量、风险警告。</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .repopilot-app { min-height: 100vh; }
  
  .rp-hero {
    padding: 6rem 0 3rem;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-page) 0%, var(--bg-section) 100%);
  }
  
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--gold-subtle);
    border: 1px solid var(--gold-border);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }
  
  .badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  
  .rp-workbench { padding: 2rem 0 4rem; }
  
  .workbench-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }
  
  @media (max-width: 1024px) {
    .workbench-grid { grid-template-columns: 1fr; }
  }
  
  .workbench-left, .workbench-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  
  .guide-card, .input-card, .repos-card {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .guide-title, .input-title, .repos-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  
  .guide-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  
  .btn-use-example {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    font-size: 0.75rem;
    cursor: pointer;
  }
  
  .rp-input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    background: var(--bg-input);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    font-size: 0.875rem;
  }
  
  .rp-input:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px var(--gold-glow);
  }
  
  .input-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  
  .btn-analyze {
    flex: 1;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-soft) 100%);
    color: var(--bg-page);
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    cursor: pointer;
  }
  
  .btn-secondary {
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
  }
  
  .repos-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .repos-empty {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-align: center;
    padding: 1rem;
  }
  
  .repo-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    cursor: pointer;
  }
  
  .repo-item:hover {
    background: var(--bg-hover);
  }
  
  .repo-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }
  
  .repo-stars {
    font-size: 0.75rem;
    color: var(--gold);
  }
  
  .mode-badge {
    display: inline-flex;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--gold-subtle);
    color: var(--gold);
    border: 1px solid var(--gold-border);
  }
  
  .hidden { display: none !important; }
  
  .empty-state {
    text-align: center;
    padding: 3rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .empty-icon { font-size: 3rem; margin-bottom: 1rem; }
  .empty-title { font-size: 1.25rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; }
  .empty-text { font-size: 0.875rem; color: var(--text-muted); }
  
  .result-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .section-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  
  .score-display {
    text-align: center;
    padding: 2rem;
  }
  
  .score-value {
    font-size: 4rem;
    font-weight: 800;
    color: var(--gold);
  }
  
  .score-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }
  
  .findings-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  
  .finding-item {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    border-left: 3px solid var(--error);
  }
  
  .finding-type {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--error);
    margin-bottom: 0.25rem;
  }
  
  .finding-description {
    font-size: 0.875rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  
  .finding-recommendation {
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  
  .recommended-action {
    margin-top: 1rem;
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--gold);
  }
  
  .deploy-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .deploy-item {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
  }
  
  .deploy-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 0.25rem;
  }
  
  .deploy-value {
    font-size: 0.875rem;
    font-family: monospace;
    color: var(--text-primary);
    word-break: break-all;
  }
  
  .faq-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  
  .faq-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  
  .faq-item {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    margin-bottom: 0.75rem;
  }
  
  .faq-question {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  
  .faq-answer {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>

<script>
  const root = document.querySelector('.repopilot-app');
  const apiBaseUrl = root?.getAttribute('data-api-base-url') || '';
  
  const inputRepo = document.getElementById('input-repo') as HTMLInputElement;
  const btnAudit = document.getElementById('btn-audit') as HTMLButtonElement;
  const btnDeploy = document.getElementById('btn-deploy') as HTMLButtonElement;
  const btnLoadTrending = document.getElementById('btn-load-trending') as HTMLButtonElement;
  
  // Demo 数据
  const demoRepos = [
    { name: 'mimo-tools', owner: 'falses00', stars: 10, description: '个人工程工具生态', language: 'TypeScript' },
    { name: 'astro', owner: 'withastro', stars: 45000, description: 'The web framework for content-driven websites', language: 'TypeScript' },
    { name: 'next.js', owner: 'vercel', stars: 120000, description: 'The React Framework', language: 'JavaScript' },
  ];
  
  // 显示热门仓库
  function showTrending() {
    const reposList = document.getElementById('repos-list');
    if (!reposList) return;
    
    reposList.innerHTML = demoRepos.map(repo => `
      <div class="repo-item" onclick="selectRepo('${repo.owner}/${repo.name}')">
        <div>
          <div class="repo-name">${repo.owner}/${repo.name}</div>
          <div style="font-size: 0.75rem; color: var(--text-muted);">${repo.description}</div>
        </div>
        <div class="repo-stars">⭐ ${repo.stars.toLocaleString()}</div>
      </div>
    `).join('');
  }
  
  // 选择仓库
  function selectRepo(repo: string) {
    inputRepo.value = repo;
  }
  
  // 安全审查
  async function auditRepo() {
    const repo = inputRepo.value.trim();
    if (!repo) {
      alert('请输入仓库地址');
      return;
    }
    
    btnAudit.disabled = true;
    btnAudit.textContent = '⏳ 审查中...';
    
    // 模拟安全审查
    await new Promise(resolve => setTimeout(resolve, 1000));
    
    const result = {
      riskScore: 85,
      findings: [
        { type: 'medium', category: 'package.json', description: '检测到 postinstall 脚本', recommendation: '检查脚本内容' },
      ],
      recommendedAction: '需要审查后部署',
    };
    
    showAuditResult(result);
    btnAudit.disabled = false;
    btnAudit.textContent = '🛡️ 安全审查';
  }
  
  // 显示审查结果
  function showAuditResult(result: any) {
    document.getElementById('empty-state')?.classList.add('hidden');
    document.getElementById('audit-section')?.classList.remove('hidden');
    document.getElementById('deploy-section')?.classList.add('hidden');
    
    const riskScore = document.getElementById('risk-score');
    if (riskScore) {
      riskScore.textContent = result.riskScore.toString();
      riskScore.style.color = result.riskScore >= 80 ? 'var(--success)' : result.riskScore >= 50 ? 'var(--warning)' : 'var(--error)';
    }
    
    const findingsList = document.getElementById('findings-list');
    if (findingsList) {
      findingsList.innerHTML = result.findings.map((f: any) => `
        <div class="finding-item">
          <div class="finding-type">${f.type}</div>
          <div class="finding-description">${f.description}</div>
          <div class="finding-recommendation">${f.recommendation}</div>
        </div>
      `).join('');
    }
    
    const recommendedAction = document.getElementById('recommended-action');
    if (recommendedAction) {
      recommendedAction.textContent = `建议: ${result.recommendedAction}`;
    }
  }
  
  // 生成部署计划
  async function generateDeployPlan() {
    const repo = inputRepo.value.trim();
    if (!repo) {
      alert('请输入仓库地址');
      return;
    }
    
    btnDeploy.disabled = true;
    btnDeploy.textContent = '⏳ 生成中...';
    
    await new Promise(resolve => setTimeout(resolve, 1000));
    
    const result = {
      cloneCommand: `git clone https://github.com/${repo}.git`,
      installCommand: 'npm install',
      devCommand: 'npm run dev',
      buildCommand: 'npm run build',
      startCommand: 'npm start',
      requiredEnvVars: ['GITHUB_TOKEN'],
      detectedFramework: 'Astro',
      ports: [4321],
      manualSteps: ['选择部署目录', '确认 clone', '配置环境变量'],
    };
    
    showDeployPlan(result);
    btnDeploy.disabled = false;
    btnDeploy.textContent = '📦 生成部署计划';
  }
  
  // 显示部署计划
  function showDeployPlan(result: any) {
    document.getElementById('empty-state')?.classList.add('hidden');
    document.getElementById('audit-section')?.classList.add('hidden');
    document.getElementById('deploy-section')?.classList.remove('hidden');
    
    const deployInfo = document.getElementById('deploy-info');
    if (deployInfo) {
      deployInfo.innerHTML = `
        <div class="deploy-item">
          <div class="deploy-label">Clone 命令</div>
          <div class="deploy-value">${result.cloneCommand}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">安装命令</div>
          <div class="deploy-value">${result.installCommand}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">开发命令</div>
          <div class="deploy-value">${result.devCommand}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">构建命令</div>
          <div class="deploy-value">${result.buildCommand}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">框架</div>
          <div class="deploy-value">${result.detectedFramework}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">端口</div>
          <div class="deploy-value">${result.ports.join(', ')}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">需要的环境变量</div>
          <div class="deploy-value">${result.requiredEnvVars.join(', ') || '无'}</div>
        </div>
        <div class="deploy-item">
          <div class="deploy-label">手动步骤</div>
          <div class="deploy-value">${result.manualSteps.join(' → ')}</div>
        </div>
      `;
    }
  }
  
  // 事件监听
  btnAudit?.addEventListener('click', auditRepo);
  btnDeploy?.addEventListener('click', generateDeployPlan);
  btnLoadTrending?.addEventListener('click', showTrending);
  
  (window as any).selectRepo = selectRepo;
</script>