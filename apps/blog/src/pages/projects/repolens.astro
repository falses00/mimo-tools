---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="RepoLens - Codebase Quality Auditor">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="mb-8">
        <a href="/mimo-tools/projects" class="inline-flex items-center gap-2 text-sm mb-4 transition-colors duration-200" style="color: var(--text-muted);">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          返回旗舰项目
        </a>
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-16 h-16 rounded-2xl" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
            <span class="text-3xl">🔍</span>
          </div>
          <div>
            <h1 class="text-3xl font-bold" style="color: var(--text-primary);">RepoLens</h1>
            <p style="color: var(--text-muted);">Codebase Quality Auditor - 代码仓库质量审计台</p>
          </div>
        </div>
      </div>

      {/* Input Section */}
      <div class="p-6 rounded-xl mb-8" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
        <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">📦 仓库分析</h3>
        <div class="space-y-4">
          <div>
            <label class="text-sm mb-2 block" style="color: var(--text-muted);">GitHub Repository (owner/repo)</label>
            <div class="flex gap-2">
              <input
                type="text"
                id="input-repo"
                class="input flex-1"
                placeholder="falses00/mimo-tools"
                value="falses00/mimo-tools"
              />
              <button id="btn-analyze" class="btn btn-primary">
                🔍 Analyze
              </button>
            </div>
          </div>
          <div>
            <label class="text-sm mb-2 block" style="color: var(--text-muted);">或上传 Repository Manifest JSON</label>
            <textarea
              id="input-manifest"
              class="textarea"
              style="min-height: 6rem;"
              placeholder='{"name":"my-repo","readme":true,"license":"MIT",...}'
            ></textarea>
          </div>
          <div class="flex flex-wrap gap-3">
            <button id="btn-manifest" class="btn btn-secondary">
              📋 分析 Manifest
            </button>
            <button id="btn-demo" class="btn btn-secondary">
              🎯 使用 Demo 数据
            </button>
            <button id="btn-export" class="btn btn-ghost">
              📥 导出报告
            </button>
          </div>
        </div>
      </div>

      {/* Results */}
      <div id="results" class="hidden space-y-6">
        {/* Score */}
        <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--gold-border);">
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">📊 Quality Score</h3>
          <div class="flex items-center gap-8">
            <div class="text-center">
              <div id="quality-score" class="text-6xl font-bold" style="color: var(--gold-primary);">0</div>
              <div class="text-sm mt-2" style="color: var(--text-muted);">总分 / 100</div>
            </div>
            <div class="flex-1">
              <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                <div class="text-center p-3 rounded-lg" style="background: var(--bg-elevated);">
                  <div class="text-2xl font-bold" id="stat-readme" style="color: var(--success);">✓</div>
                  <div class="text-xs" style="color: var(--text-muted);">README</div>
                </div>
                <div class="text-center p-3 rounded-lg" style="background: var(--bg-elevated);">
                  <div class="text-2xl font-bold" id="stat-license" style="color: var(--success);">✓</div>
                  <div class="text-xs" style="color: var(--text-muted);">LICENSE</div>
                </div>
                <div class="text-center p-3 rounded-lg" style="background: var(--bg-elevated);">
                  <div class="text-2xl font-bold" id="stat-tests" style="color: var(--success);">✓</div>
                  <div class="text-xs" style="color: var(--text-muted);">Tests</div>
                </div>
                <div class="text-center p-3 rounded-lg" style="background: var(--bg-elevated);">
                  <div class="text-2xl font-bold" id="stat-ci" style="color: var(--success);">✓</div>
                  <div class="text-xs" style="color: var(--text-muted);">CI/CD</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Details */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          {/* Repository Info */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">📋 仓库信息</h3>
            <div id="repo-info" class="space-y-3 text-sm" style="color: var(--text-secondary);"></div>
          </div>

          {/* Checks */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">✅ 质量检查</h3>
            <div id="checks-list" class="space-y-2"></div>
          </div>
        </div>

        {/* Recommendations */}
        <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">💡 优先改进建议</h3>
          <div id="recommendations" class="space-y-2"></div>
        </div>
      </div>

      {/* Empty State */}
      <div id="empty-state" class="p-12 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
        <div class="text-6xl mb-4">🔍</div>
        <h3 class="text-xl font-semibold mb-2" style="color: var(--text-primary);">开始分析</h3>
        <p style="color: var(--text-muted);">输入 GitHub 仓库地址或上传 manifest，分析代码质量</p>
      </div>

      {/* Status Bar */}
      <div id="status-bar" class="mt-6 p-3 rounded-lg text-sm hidden"></div>
    </div>
  </div>
</Layout>

<script>
  interface RepoManifest {
    name: string;
    owner: string;
    description?: string;
    readme: boolean;
    license?: string;
    hasTests: boolean;
    testFramework?: string;
    hasCI: boolean;
    ciProvider?: string;
    hasDocs: boolean;
    languages: Record<string, number>;
    scripts: string[];
    dependencies: number;
    devDependencies: number;
  }

  interface AnalysisResult {
    score: number;
    checks: Array<{ name: string; passed: boolean; details?: string }>;
    recommendations: string[];
    info: Record<string, string>;
  }

  const inputRepo = document.getElementById('input-repo') as HTMLInputElement;
  const inputManifest = document.getElementById('input-manifest') as HTMLTextAreaElement;
  const results = document.getElementById('results') as HTMLDivElement;
  const emptyState = document.getElementById('empty-state') as HTMLDivElement;
  const statusBar = document.getElementById('status-bar') as HTMLDivElement;

  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    statusBar.className = 'mt-6 p-3 rounded-lg text-sm block';
    statusBar.style.background = type === 'success' ? 'var(--success-muted)' : type === 'error' ? 'var(--error-muted)' : 'var(--info-muted)';
    statusBar.style.color = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--error)' : 'var(--info)';
    statusBar.textContent = msg;
  }

  function getDemoManifest(): RepoManifest {
    return {
      name: 'mimo-tools',
      owner: 'falses00',
      description: '个人工具生态：包含多个实用工具、博客和导航站',
      readme: true,
      license: 'MIT',
      hasTests: true,
      testFramework: 'Vitest',
      hasCI: true,
      ciProvider: 'GitHub Actions',
      hasDocs: true,
      languages: { TypeScript: 65, Astro: 20, CSS: 10, JavaScript: 5 },
      scripts: ['dev', 'build', 'test', 'lint', 'typecheck'],
      dependencies: 15,
      devDependencies: 8,
    };
  }

  function analyzeManifest(manifest: RepoManifest): AnalysisResult {
    const checks: AnalysisResult['checks'] = [];
    const recommendations: string[] = [];
    let score = 0;

    // README check
    checks.push({
      name: 'README',
      passed: manifest.readme,
      details: manifest.readme ? 'README 文件存在' : '缺少 README 文件',
    });
    if (manifest.readme) score += 15;
    else recommendations.push('添加 README.md 文件，包含项目说明和使用方法');

    // LICENSE check
    checks.push({
      name: 'LICENSE',
      passed: !!manifest.license,
      details: manifest.license ? `许可证: ${manifest.license}` : '缺少 LICENSE 文件',
    });
    if (manifest.license) score += 10;
    else recommendations.push('添加 LICENSE 文件，明确开源协议');

    // Tests check
    checks.push({
      name: 'Tests',
      passed: manifest.hasTests,
      details: manifest.hasTests ? `测试框架: ${manifest.testFramework}` : '未发现测试配置',
    });
    if (manifest.hasTests) score += 20;
    else recommendations.push('添加单元测试，使用 Vitest 或 Jest');

    // CI check
    checks.push({
      name: 'CI/CD',
      passed: manifest.hasCI,
      details: manifest.hasCI ? `CI 平台: ${manifest.ciProvider}` : '未发现 CI 配置',
    });
    if (manifest.hasCI) score += 20;
    else recommendations.push('配置 GitHub Actions 自动化测试和部署');

    // Docs check
    checks.push({
      name: 'Documentation',
      passed: manifest.hasDocs,
      details: manifest.hasDocs ? '文档齐全' : '缺少文档',
    });
    if (manifest.hasDocs) score += 15;
    else recommendations.push('添加 docs/ 目录，包含使用文档和 API 说明');

    // Scripts check
    const essentialScripts = ['dev', 'build', 'test'];
    const hasEssentials = essentialScripts.every(s => manifest.scripts.includes(s));
    checks.push({
      name: 'Package Scripts',
      passed: hasEssentials,
      details: hasEssentials ? '必需脚本齐全' : '缺少必需脚本',
    });
    if (hasEssentials) score += 10;
    else recommendations.push('确保 package.json 包含 dev, build, test 脚本');

    // Languages check
    const hasTypeScript = 'TypeScript' in manifest.languages;
    checks.push({
      name: 'TypeScript',
      passed: hasTypeScript,
      details: hasTypeScript ? '使用 TypeScript' : '未使用 TypeScript',
    });
    if (hasTypeScript) score += 10;
    else recommendations.push('考虑使用 TypeScript 提高代码质量');

    // Info
    const info: Record<string, string> = {
      '仓库名称': `${manifest.owner}/${manifest.name}`,
      '描述': manifest.description || '无描述',
      '主要语言': Object.entries(manifest.languages).sort((a, b) => b[1] - a[1])[0]?.[0] || '未知',
      '依赖数量': `${manifest.dependencies} dependencies, ${manifest.devDependencies} devDependencies`,
      '脚本': manifest.scripts.join(', '),
    };

    return { score: Math.min(100, score), checks, recommendations, info };
  }

  function displayResults(result: AnalysisResult) {
    emptyState.classList.add('hidden');
    results.classList.remove('hidden');

    // Update score
    const qualityScore = document.getElementById('quality-score') as HTMLDivElement;
    qualityScore.textContent = result.score.toString();
    qualityScore.style.color = result.score >= 80 ? 'var(--success)' : result.score >= 60 ? 'var(--warning)' : 'var(--error)';

    // Update stats
    const readmeCheck = result.checks.find(c => c.name === 'README');
    const licenseCheck = result.checks.find(c => c.name === 'LICENSE');
    const testsCheck = result.checks.find(c => c.name === 'Tests');
    const ciCheck = result.checks.find(c => c.name === 'CI/CD');

    document.getElementById('stat-readme')!.textContent = readmeCheck?.passed ? '✓' : '✗';
    document.getElementById('stat-readme')!.style.color = readmeCheck?.passed ? 'var(--success)' : 'var(--error)';
    document.getElementById('stat-license')!.textContent = licenseCheck?.passed ? '✓' : '✗';
    document.getElementById('stat-license')!.style.color = licenseCheck?.passed ? 'var(--success)' : 'var(--error)';
    document.getElementById('stat-tests')!.textContent = testsCheck?.passed ? '✓' : '✗';
    document.getElementById('stat-tests')!.style.color = testsCheck?.passed ? 'var(--success)' : 'var(--error)';
    document.getElementById('stat-ci')!.textContent = ciCheck?.passed ? '✓' : '✗';
    document.getElementById('stat-ci')!.style.color = ciCheck?.passed ? 'var(--success)' : 'var(--error)';

    // Display repo info
    const repoInfo = document.getElementById('repo-info') as HTMLDivElement;
    repoInfo.innerHTML = Object.entries(result.info).map(([key, value]) => `
      <div class="flex justify-between">
        <span>${key}</span>
        <span class="font-medium" style="color: var(--text-primary);">${value}</span>
      </div>
    `).join('');

    // Display checks
    const checksList = document.getElementById('checks-list') as HTMLDivElement;
    checksList.innerHTML = result.checks.map(check => `
      <div class="flex items-center gap-3 p-3 rounded-lg" style="background: var(--bg-elevated);">
        <span style="color: ${check.passed ? 'var(--success)' : 'var(--error)'};">${check.passed ? '✓' : '✗'}</span>
        <div>
          <span class="text-sm font-medium" style="color: var(--text-primary);">${check.name}</span>
          ${check.details ? `<p class="text-xs" style="color: var(--text-muted);">${check.details}</p>` : ''}
        </div>
      </div>
    `).join('');

    // Display recommendations
    const recommendations = document.getElementById('recommendations') as HTMLDivElement;
    if (result.recommendations.length > 0) {
      recommendations.innerHTML = result.recommendations.map((rec, i) => `
        <div class="flex items-start gap-3 p-3 rounded-lg" style="background: var(--bg-elevated);">
          <span class="font-bold" style="color: var(--gold-primary);">${i + 1}</span>
          <span class="text-sm" style="color: var(--text-secondary);">${rec}</span>
        </div>
      `).join('');
    } else {
      recommendations.innerHTML = '<p class="text-sm" style="color: var(--success);">所有检查通过，仓库质量优秀！</p>';
    }
  }

  // Event listeners
  document.getElementById('btn-analyze')?.addEventListener('click', () => {
    const repo = inputRepo.value.trim();
    if (!repo) {
      showStatus('请输入仓库地址', 'error');
      return;
    }

    showStatus('正在分析...', 'info');

    // Use demo data for static mode
    setTimeout(() => {
      const manifest = getDemoManifest();
      const result = analyzeManifest(manifest);
      displayResults(result);
      showStatus('Static Demo Mode - 使用内置数据', 'info');
    }, 1000);
  });

  document.getElementById('btn-manifest')?.addEventListener('click', () => {
    const manifestStr = inputManifest.value.trim();
    if (!manifestStr) {
      showStatus('请粘贴 Manifest JSON', 'error');
      return;
    }

    try {
      const manifest = JSON.parse(manifestStr) as RepoManifest;
      showStatus('正在分析...', 'info');

      setTimeout(() => {
        const result = analyzeManifest(manifest);
        displayResults(result);
        showStatus('分析完成', 'success');
      }, 500);
    } catch (error) {
      showStatus('JSON 解析失败: ' + error, 'error');
    }
  });

  document.getElementById('btn-demo')?.addEventListener('click', () => {
    showStatus('加载 Demo 数据...', 'info');

    setTimeout(() => {
      const manifest = getDemoManifest();
      const result = analyzeManifest(manifest);
      displayResults(result);
      showStatus('Demo 数据加载完成', 'success');
    }, 500);
  });

  document.getElementById('btn-export')?.addEventListener('click', () => {
    const score = document.getElementById('quality-score')?.textContent || '0';
    const checks = Array.from(document.querySelectorAll('#checks-list .flex')).map(el => el.textContent).join('\n');

    const report = `# RepoLens 质量审计报告

## 质量评分: ${score}/100

## 质量检查:
${checks || '无数据'}

## 建议:
- 确保 README 完整
- 添加测试覆盖
- 配置 CI/CD
- 完善文档

---
Generated by RepoLens - MIMO Tools
`;

    const blob = new Blob([report], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'repolens-report.md';
    a.click();
    URL.revokeObjectURL(url);
    showStatus('报告已导出', 'success');
  });
</script>