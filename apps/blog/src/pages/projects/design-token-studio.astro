---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Design Token Studio - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="mb-8">
        <a href="/projects" class="inline-flex items-center gap-2 text-sm mb-4 transition-colors duration-200" style="color: var(--text-muted);">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          返回旗舰项目
        </a>
        <div class="flex items-center gap-4">
          <div class="flex items-center justify-center w-16 h-16 rounded-2xl" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
            <span class="text-3xl">🎨</span>
          </div>
          <div>
            <h1 class="text-3xl font-bold" style="color: var(--text-primary);">Design Token Studio</h1>
            <p style="color: var(--text-muted);">设计系统 Token 生成与预览工具</p>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {/* Controls */}
        <div class="space-y-6">
          {/* Color Input */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">🎨 主色设置</h3>
            <div class="space-y-4">
              <div>
                <label class="text-sm mb-2 block" style="color: var(--text-muted);">主色 (HEX)</label>
                <div class="flex gap-2">
                  <input
                    type="color"
                    id="input-color"
                    class="w-12 h-10 rounded cursor-pointer"
                    value="#d4af37"
                  />
                  <input
                    type="text"
                    id="input-hex"
                    class="input flex-1 font-mono"
                    value="#d4af37"
                  />
                </div>
              </div>
              <div>
                <label class="text-sm mb-2 block" style="color: var(--text-muted);">预设主题</label>
                <div class="flex flex-wrap gap-2">
                  <button class="btn btn-secondary text-xs" onclick="applyPreset('dark-gold')">Dark Gold</button>
                  <button class="btn btn-secondary text-xs" onclick="applyPreset('ocean-blue')">Ocean Blue</button>
                  <button class="btn btn-secondary text-xs" onclick="applyPreset('forest-green')">Forest Green</button>
                  <button class="btn btn-secondary text-xs" onclick="applyPreset('royal-purple')">Royal Purple</button>
                </div>
              </div>
            </div>
          </div>

          {/* Generated Tokens */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold" style="color: var(--text-primary);">📝 CSS Variables</h3>
              <button class="btn btn-ghost text-xs" onclick="copyCSS()">复制 CSS</button>
            </div>
            <pre class="p-4 rounded-lg overflow-auto max-h-64 text-xs" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
              <code id="css-output" style="color: var(--text-secondary);"></code>
            </pre>
          </div>

          {/* Tailwind Config */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-between mb-4">
              <h3 class="text-lg font-semibold" style="color: var(--text-primary);">⚙️ Tailwind Config</h3>
              <button class="btn btn-ghost text-xs" onclick="copyTailwind()">复制</button>
            </div>
            <pre class="p-4 rounded-lg overflow-auto max-h-48 text-xs" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
              <code id="tailwind-output" style="color: var(--text-secondary);"></code>
            </pre>
          </div>
        </div>

        {/* Preview */}
        <div class="space-y-6">
          {/* Color Scale */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">🎯 颜色比例</h3>
            <div id="color-scale" class="grid grid-cols-5 gap-2"></div>
          </div>

          {/* Button Preview */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">🔘 按钮预览</h3>
            <div class="flex flex-wrap gap-3">
              <button id="preview-btn-primary" class="btn btn-primary">Primary</button>
              <button id="preview-btn-secondary" class="btn btn-secondary">Secondary</button>
              <button id="preview-btn-ghost" class="btn btn-ghost">Ghost</button>
              <button id="preview-btn-outline" class="btn btn-gold-outline">Outline</button>
            </div>
          </div>

          {/* Card Preview */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">🃏 卡片预览</h3>
            <div id="preview-card" class="p-4 rounded-lg" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
              <h4 class="font-semibold mb-2" style="color: var(--text-primary);">Card Title</h4>
              <p class="text-sm" style="color: var(--text-muted);">This is a preview card with the generated tokens.</p>
            </div>
          </div>

          {/* Badge Preview */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">🏷️ Badge 预览</h3>
            <div class="flex flex-wrap gap-2">
              <span id="preview-badge-primary" class="badge badge-gold">Primary</span>
              <span id="preview-badge-success" class="badge badge-success">Success</span>
              <span id="preview-badge-error" class="badge badge-error">Error</span>
              <span id="preview-badge-info" class="badge" style="background: var(--info-muted); color: var(--info);">Info</span>
            </div>
          </div>

          {/* Input Preview */}
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">📝 输入框预览</h3>
            <input type="text" class="input" placeholder="Focus me to see the ring color..." />
          </div>
        </div>
      </div>

      {/* Status Bar */}
      <div id="status-bar" class="mt-6 p-3 rounded-lg text-sm hidden"></div>
    </div>
  </div>
</Layout>

<script>
  const inputColor = document.getElementById('input-color') as HTMLInputElement;
  const inputHex = document.getElementById('input-hex') as HTMLInputElement;
  const cssOutput = document.getElementById('css-output') as HTMLElement;
  const tailwindOutput = document.getElementById('tailwind-output') as HTMLElement;
  const statusBar = document.getElementById('status-bar') as HTMLDivElement;

  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    statusBar.className = 'mt-6 p-3 rounded-lg text-sm block';
    statusBar.style.background = type === 'success' ? 'var(--success-muted)' : type === 'error' ? 'var(--error-muted)' : 'var(--info-muted)';
    statusBar.style.color = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--error)' : 'var(--info)';
    statusBar.textContent = msg;
  }

  function hexToHSL(hex: string): { h: number; s: number; l: number } {
    const r = parseInt(hex.slice(1, 3), 16) / 255;
    const g = parseInt(hex.slice(3, 5), 16) / 255;
    const b = parseInt(hex.slice(5, 7), 16) / 255;
    
    const max = Math.max(r, g, b);
    const min = Math.min(r, g, b);
    let h = 0, s = 0;
    const l = (max + min) / 2;
    
    if (max !== min) {
      const d = max - min;
      s = l > 0.5 ? d / (2 - max - min) : d / (max + min);
      
      switch (max) {
        case r: h = ((g - b) / d + (g < b ? 6 : 0)) / 6; break;
        case g: h = ((b - r) / d + 2) / 6; break;
        case b: h = ((r - g) / d + 4) / 6; break;
      }
    }
    
    return { h: Math.round(h * 360), s: Math.round(s * 100), l: Math.round(l * 100) };
  }

  function generateColorScale(hex: string): string[] {
    const hsl = hexToHSL(hex);
    const scales = [50, 100, 200, 300, 400, 500, 600, 700, 800, 900];
    
    return scales.map(scale => {
      const lightness = 95 - (scale / 100) * 80;
      return `hsl(${hsl.h}, ${hsl.s}%, ${lightness}%)`;
    });
  }

  function generateTokens(hex: string) {
    const hsl = hexToHSL(hex);
    const scale = generateColorScale(hex);
    
    // Update color scale display
    const colorScale = document.getElementById('color-scale') as HTMLDivElement;
    colorScale.innerHTML = scale.map((color, i) => `
      <div class="text-center">
        <div class="h-12 rounded-lg mb-1" style="background: ${color};"></div>
        <div class="text-xs" style="color: var(--text-muted);">${(i + 1) * 100}</div>
      </div>
    `).join('');
    
    // Update preview elements
    document.documentElement.style.setProperty('--preview-primary', hex);
    document.documentElement.style.setProperty('--preview-glow', `${hex}30`);
    
    const btnPrimary = document.getElementById('preview-btn-primary');
    if (btnPrimary) btnPrimary.style.background = hex;
    
    const badgePrimary = document.getElementById('preview-badge-primary');
    if (badgePrimary) {
      badgePrimary.style.background = `${hex}20`;
      badgePrimary.style.borderColor = `${hex}50`;
      badgePrimary.style.color = hex;
    }
    
    // Generate CSS
    const css = `:root {
  /* Primary Colors */
  --color-primary: ${hex};
  --color-primary-hsl: ${hsl.h} ${hsl.s}% ${hsl.l}%;
  
  /* Color Scale */
${scale.map((c, i) => `  --color-${(i + 1) * 100}: ${c};`).join('\n')}
  
  /* Surfaces */
  --bg-page: #0f1115;
  --bg-elevated: #151922;
  --bg-card: #181d27;
  
  /* Text */
  --text-primary: #f5f2ea;
  --text-secondary: #c8c0b2;
  --text-muted: #9a9388;
  
  /* Borders */
  --border-subtle: rgba(255,255,255,0.06);
  --border-default: rgba(255,255,255,0.1);
  --border-gold: ${hex}50;
  
  /* Effects */
  --glow-gold: ${hex}30;
  --shadow-gold: 0 0 20px ${hex}30;
}`;
    
    cssOutput.textContent = css;
    
    // Generate Tailwind config
    const tailwind = `// tailwind.config.js
module.exports = {
  theme: {
    extend: {
      colors: {
        primary: {
          DEFAULT: '${hex}',
          50: '${scale[0]}',
          100: '${scale[1]}',
          200: '${scale[2]}',
          300: '${scale[3]}',
          400: '${scale[4]}',
          500: '${scale[5]}',
          600: '${scale[6]}',
          700: '${scale[7]}',
          800: '${scale[8]}',
          900: '${scale[9]}',
        },
      },
    },
  },
}`;
    
    tailwindOutput.textContent = tailwind;
  }

  function applyPreset(preset: string) {
    const presets: Record<string, string> = {
      'dark-gold': '#d4af37',
      'ocean-blue': '#3b82f6',
      'forest-green': '#22c55e',
      'royal-purple': '#a855f7',
    };
    
    const color = presets[preset];
    if (color) {
      inputColor.value = color;
      inputHex.value = color;
      generateTokens(color);
      showStatus(`已应用 ${preset} 主题`, 'success');
    }
  }

  function copyCSS() {
    navigator.clipboard.writeText(cssOutput.textContent || '');
    showStatus('CSS 已复制', 'success');
  }

  function copyTailwind() {
    navigator.clipboard.writeText(tailwindOutput.textContent || '');
    showStatus('Tailwind config 已复制', 'success');
  }

  // Event listeners
  inputColor.addEventListener('input', (e) => {
    const color = (e.target as HTMLInputElement).value;
    inputHex.value = color;
    generateTokens(color);
  });

  inputHex.addEventListener('input', (e) => {
    const hex = (e.target as HTMLInputElement).value;
    if (/^#[0-9A-Fa-f]{6}$/.test(hex)) {
      inputColor.value = hex;
      generateTokens(hex);
    }
  });

  // Make functions globally available
  (window as any).applyPreset = applyPreset;
  (window as any).copyCSS = copyCSS;
  (window as any).copyTailwind = copyTailwind;

  // Initial generation
  generateTokens('#d4af37');
</script>