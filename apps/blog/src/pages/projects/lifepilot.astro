---
import Layout from '../../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const apiBaseUrl = import.meta.env.PUBLIC_API_BASE_URL ?? '';
---

<Layout title="LifePilot AI 生活管家 - MIMO" description="用一句话记录今天做了什么、接下来要做什么，自动生成已办、待办、提醒和生活计划。">
  <div class="lifepilot-app" data-api-base-url={apiBaseUrl}>
    {/* Hero Section */}
    <section class="lifepilot-hero">
      <div class="container">
        <div class="hero-content">
          <div class="hero-badge">
            <span class="badge-dot"></span>
            <span>AI 生活管家</span>
          </div>
          <h1 class="hero-title">LifePilot</h1>
          <p class="hero-subtitle">
            用一句话记录今天做了什么、接下来要做什么，自动生成已办、待办、提醒和生活计划。
          </p>
        </div>
      </div>
    </section>

    {/* Main Workbench */}
    <section class="lifepilot-workbench">
      <div class="container">
        <div class="workbench-grid">
          {/* Left: Input & Settings */}
          <div class="workbench-left">
            {/* 新手引导 */}
            <div class="guide-card">
              <h3 class="guide-title">💡 新手引导</h3>
              <p class="guide-text">
                试试输入这句话：
              </p>
              <div class="guide-example" id="guide-example">
                我今天完成了博客首页优化，跑步 3 公里，明天上午要投简历，周五前准备 AI 面试项目。
              </div>
              <button class="btn-use-example" id="btn-use-example">
                使用这个示例
              </button>
            </div>

            {/* 输入区 */}
            <div class="input-card">
              <h3 class="input-title">✍️ 记录你的生活</h3>
              <textarea
                id="life-input"
                class="life-textarea"
                placeholder="输入一句话，例如：我今天写完了博客，跑了 3 公里，明天要投简历..."
                rows="4"
              ></textarea>
              <div class="input-actions">
                <button class="btn-generate" id="btn-generate">
                  🚀 生成我的生活计划
                </button>
                <button class="btn-clear" id="btn-clear">
                  清空
                </button>
              </div>
              <div class="input-hint">
                支持自然语言输入，系统会自动识别已完成、待办、习惯、账单等
              </div>
            </div>

            {/* 设置区 */}
            <div class="settings-card">
              <h3 class="settings-title">⚙️ 设置</h3>
              <div class="settings-list">
                <div class="setting-item">
                  <label class="setting-label">工作日开始时间</label>
                  <input type="time" id="setting-workday-start" class="setting-input" value="09:00" />
                </div>
                <div class="setting-item">
                  <label class="setting-label">默认提醒时间</label>
                  <input type="time" id="setting-reminder-time" class="setting-input" value="08:00" />
                </div>
                <div class="setting-item">
                  <label class="setting-label">数据保存模式</label>
                  <select id="setting-save-mode" class="setting-select">
                    <option value="local">本地浏览器</option>
                    <option value="api">API 模式</option>
                  </select>
                </div>
              </div>
            </div>
          </div>

          {/* Right: Results */}
          <div class="workbench-right">
            {/* Mode Badge */}
            <div class="mode-badge-container">
              <span id="mode-badge" class="mode-badge">
                {apiBaseUrl ? 'API 模式' : '本地模式'}
              </span>
              <span id="duration-badge" class="duration-badge hidden"></span>
            </div>

            {/* 结果区 */}
            <div id="results-area" class="results-area">
              {/* 空状态 */}
              <div id="empty-state" class="empty-state">
                <div class="empty-icon">📝</div>
                <h3 class="empty-title">开始记录</h3>
                <p class="empty-text">输入一句话，系统会自动解析成已办、待办、提醒和计划</p>
              </div>

              {/* 已完成 */}
              <div id="done-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">✅</span>
                  已完成
                  <span id="done-count" class="section-count">0</span>
                </h3>
                <div id="done-list" class="items-list"></div>
              </div>

              {/* 待办事项 */}
              <div id="todos-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">📋</span>
                  待办事项
                  <span id="todos-count" class="section-count">0</span>
                </h3>
                <div id="todos-list" class="items-list"></div>
              </div>

              {/* 习惯记录 */}
              <div id="habits-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">🏃</span>
                  习惯记录
                  <span id="habits-count" class="section-count">0</span>
                </h3>
                <div id="habits-list" class="items-list"></div>
              </div>

              {/* 账单/支出 */}
              <div id="bills-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">💰</span>
                  账单/支出
                  <span id="bills-count" class="section-count">0</span>
                </h3>
                <div id="bills-list" class="items-list"></div>
              </div>

              {/* 项目进度 */}
              <div id="projects-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">🚀</span>
                  项目进度
                  <span id="projects-count" class="section-count">0</span>
                </h3>
                <div id="projects-list" class="items-list"></div>
              </div>

              {/* 智能建议 */}
              <div id="suggestions-section" class="result-section hidden">
                <h3 class="section-title">
                  <span class="section-icon">💡</span>
                  智能建议
                </h3>
                <div id="suggestions-list" class="suggestions-list"></div>
              </div>
            </div>

            {/* 操作按钮 */}
            <div id="action-buttons" class="action-buttons hidden">
              <button class="btn-save" id="btn-save">
                💾 保存记录
              </button>
              <button class="btn-export" id="btn-export">
                📄 导出日报
              </button>
            </div>

            {/* 今日时间线 */}
            <div id="timeline-section" class="timeline-section hidden">
              <h3 class="timeline-title">📅 今日时间线</h3>
              <div id="timeline-list" class="timeline-list"></div>
            </div>

            {/* 历史记录 */}
            <div id="history-section" class="history-section">
              <h3 class="history-title">📚 历史记录</h3>
              <div id="history-list" class="history-list">
                <p class="history-empty">暂无历史记录</p>
              </div>
            </div>

            {/* FAQ */}
            <div class="faq-section">
              <h3 class="faq-title">❓ 常见问题</h3>
              <div class="faq-list">
                <div class="faq-item">
                  <div class="faq-question">数据保存在哪里？</div>
                  <div class="faq-answer">
                    默认保存在浏览器本地存储（localStorage）。如果配置了 API 模式，数据会同步到后端服务器。
                  </div>
                </div>
                <div class="faq-item">
                  <div class="faq-question">没有后端时如何工作？</div>
                  <div class="faq-answer">
                    所有功能都可以在本地使用，数据保存在浏览器中。配置 API 后可以实现数据同步和多设备访问。
                  </div>
                </div>
                <div class="faq-item">
                  <div class="faq-question">API 模式是什么？</div>
                  <div class="faq-answer">
                    API 模式会将数据发送到后端服务器处理，可以实现更智能的解析和数据持久化。
                  </div>
                </div>
                <div class="faq-item">
                  <div class="faq-question">AI 增强需要哪些配置？</div>
                  <div class="faq-answer">
                    当前版本使用规则解析，不需要额外配置。未来版本会支持 AI 增强解析。
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .lifepilot-app {
    min-height: 100vh;
  }

  /* Hero */
  .lifepilot-hero {
    padding: 6rem 0 3rem;
    text-align: center;
    background: linear-gradient(180deg, var(--bg-page) 0%, var(--bg-section) 100%);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 9999px;
    background: var(--gold-subtle);
    border: 1px solid var(--gold-border);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 1.5rem;
  }

  .badge-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--gold);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.125rem;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Workbench */
  .lifepilot-workbench {
    padding: 2rem 0 4rem;
  }

  .workbench-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 1024px) {
    .workbench-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Left Panel */
  .workbench-left {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .guide-card, .input-card, .settings-card {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .guide-title, .input-title, .settings-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .guide-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .guide-example {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    font-size: 0.875rem;
    color: var(--text-secondary);
    cursor: pointer;
    transition: all 0.2s;
    line-height: 1.6;
  }

  .guide-example:hover {
    background: var(--bg-hover);
    border-color: var(--gold-border);
  }

  .btn-use-example {
    margin-top: 0.75rem;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-use-example:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .life-textarea {
    width: 100%;
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-input);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    font-size: 0.875rem;
    line-height: 1.6;
    resize: vertical;
    transition: all 0.2s;
  }

  .life-textarea:focus {
    outline: none;
    border-color: var(--gold);
    box-shadow: 0 0 0 3px var(--gold-glow);
  }

  .life-textarea::placeholder {
    color: var(--text-muted);
  }

  .input-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .btn-generate {
    flex: 1;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-soft) 100%);
    color: var(--bg-page);
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-generate:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--gold-glow);
  }

  .btn-clear {
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    font-size: 0.875rem;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-clear:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .input-hint {
    margin-top: 0.75rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .settings-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .setting-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .setting-label {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  .setting-input, .setting-select {
    padding: 0.5rem;
    border-radius: 0.375rem;
    background: var(--bg-input);
    border: 1px solid var(--border-default);
    color: var(--text-primary);
    font-size: 0.875rem;
  }

  /* Right Panel */
  .workbench-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mode-badge-container {
    display: flex;
    gap: 0.5rem;
  }

  .mode-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--gold-subtle);
    color: var(--gold);
    border: 1px solid var(--gold-border);
  }

  .duration-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    background: var(--bg-elevated);
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
  }

  .hidden {
    display: none !important;
  }

  /* Results Area */
  .results-area {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .empty-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .empty-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .empty-text {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .result-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .section-icon {
    font-size: 1.25rem;
  }

  .section-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: var(--gold-subtle);
    color: var(--gold);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .items-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .item-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    transition: all 0.2s;
  }

  .item-card:hover {
    background: var(--bg-hover);
    border-color: var(--border-default);
  }

  .item-checkbox {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 0.25rem;
    border: 2px solid var(--border-default);
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .item-checkbox.checked {
    background: var(--gold);
    border-color: var(--gold);
  }

  .item-content {
    flex: 1;
    min-width: 0;
  }

  .item-title {
    font-size: 0.875rem;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }

  .item-title.completed {
    text-decoration: line-through;
    color: var(--text-muted);
  }

  .item-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .item-category {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    background: var(--bg-hover);
    font-size: 0.625rem;
  }

  .item-due {
    color: var(--gold);
  }

  .item-priority {
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.625rem;
  }

  .priority-high {
    background: rgba(248, 113, 113, 0.15);
    color: #f87171;
  }

  .priority-medium {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
  }

  .priority-low {
    background: rgba(74, 222, 128, 0.15);
    color: #4ade80;
  }

  .item-actions {
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .item-card:hover .item-actions {
    opacity: 1;
  }

  .item-btn {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.375rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.75rem;
  }

  .item-btn:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .item-btn.delete:hover {
    background: rgba(248, 113, 113, 0.15);
    color: #f87171;
  }

  .suggestions-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .suggestion-item {
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  /* Action Buttons */
  .action-buttons {
    display: flex;
    gap: 0.75rem;
  }

  .btn-save, .btn-export {
    flex: 1;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }

  .btn-save {
    background: linear-gradient(135deg, var(--gold) 0%, var(--gold-soft) 100%);
    color: var(--bg-page);
  }

  .btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--gold-glow);
  }

  .btn-export {
    background: var(--bg-elevated);
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
  }

  .btn-export:hover {
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  /* Timeline */
  .timeline-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .timeline-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .timeline-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .timeline-item {
    display: flex;
    gap: 1rem;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
  }

  .timeline-time {
    font-size: 0.75rem;
    color: var(--gold);
    font-weight: 600;
    white-space: nowrap;
  }

  .timeline-text {
    font-size: 0.875rem;
    color: var(--text-secondary);
  }

  /* History */
  .history-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .history-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .history-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .history-empty {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-align: center;
    padding: 1rem;
  }

  .history-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
    cursor: pointer;
    transition: all 0.2s;
  }

  .history-item:hover {
    background: var(--bg-hover);
  }

  .history-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .history-text {
    font-size: 0.875rem;
    color: var(--text-secondary);
    flex: 1;
    margin: 0 1rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .history-count {
    font-size: 0.75rem;
    color: var(--gold);
  }

  /* FAQ */
  .faq-section {
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }

  .faq-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    padding: 1rem;
    border-radius: 0.5rem;
    background: var(--bg-elevated);
  }

  .faq-question {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .faq-answer {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }
</style>

<script>
  const root = document.querySelector('.lifepilot-app');
  const apiBaseUrl = root?.getAttribute('data-api-base-url') || '';

  // Elements
  const lifeInput = document.getElementById('life-input') as HTMLTextAreaElement;
  const btnGenerate = document.getElementById('btn-generate') as HTMLButtonElement;
  const btnClear = document.getElementById('btn-clear') as HTMLButtonElement;
  const btnUseExample = document.getElementById('btn-use-example') as HTMLButtonElement;
  const btnSave = document.getElementById('btn-save') as HTMLButtonElement;
  const btnExport = document.getElementById('btn-export') as HTMLButtonElement;

  // State
  let currentItems: any[] = [];
  let currentEntryText = '';

  // Guide example
  const guideExample = '我今天完成了博客首页优化，跑步 3 公里，明天上午要投简历，周五前准备 AI 面试项目。';

  // Local parser
  function parseLocally(text: string) {
    const done: any[] = [];
    const todos: any[] = [];
    const habits: any[] = [];
    const bills: any[] = [];
    const projects: any[] = [];
    const suggestions: string[] = [];

    const doneKeywords = ['完成了', '写完了', '做完了', '跑了', '学了', '看完了', '交了', '处理了', '已经', '搞定'];
    const todoKeywords = ['要', '需要', '计划', '准备', '记得', '明天', '后天', '周五前', '下周'];
    const habitKeywords = ['跑步', '健身', '阅读', '学习', '冥想', '睡觉', '喝水', '运动'];
    const billKeywords = ['交了', '支付', '花了', '买了', '续费', '房租', '服务器', '订阅'];
    const projectKeywords = ['项目', '部署', 'README', '测试', '前端', '后端', '面试', 'GitHub'];

    const segments = text.split(/[,，。；;、\n]+/).filter(s => s.trim());

    for (const segment of segments) {
      const trimmed = segment.trim();
      if (!trimmed) continue;

      const isDone = doneKeywords.some(kw => trimmed.includes(kw));
      const isTodo = todoKeywords.some(kw => trimmed.includes(kw));
      const isHabit = habitKeywords.some(kw => trimmed.includes(kw));
      const isBill = billKeywords.some(kw => trimmed.includes(kw));
      const isProject = projectKeywords.some(kw => trimmed.includes(kw));

      if (isDone) {
        const item = {
          id: `item_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
          title: trimmed,
          category: isHabit ? '健康' : isBill ? '账单' : isProject ? '项目' : '其他',
          status: 'done',
          completed: false,
        };
        done.push(item);
        if (isHabit) habits.push({ ...item, status: 'habit' });
        if (isBill) bills.push({ ...item, status: 'bill' });
      } else if (isTodo || isProject) {
        const dueText = trimmed.includes('明天') ? '明天' : 
                       trimmed.includes('后天') ? '后天' : 
                       trimmed.includes('周五') ? '周五' : 
                       trimmed.includes('下周') ? '下周' : undefined;
        
        todos.push({
          id: `item_${Date.now()}_${Math.random().toString(36).substr(2, 9)}`,
          title: trimmed,
          category: isProject ? '项目' : '其他',
          status: 'todo',
          completed: false,
          dueText,
          priority: isProject ? 'high' : 'medium',
        });
        if (isProject) projects.push({ title: trimmed, status: 'project' });
      }
    }

    if (todos.length > 0) {
      suggestions.push(`建议今天先完成: ${todos[0].title}`);
    }
    if (habits.length > 0) {
      suggestions.push('坚持记录习惯，有助于养成好习惯');
    }

    return { done, todos, habits, bills, projects, suggestions };
  }

  // API call
  async function callApi(text: string) {
    if (!apiBaseUrl) return null;
    
    try {
      const response = await fetch(`${apiBaseUrl}/api/lifepilot/parse-entry`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text }),
        signal: AbortSignal.timeout(30000),
      });
      
      if (!response.ok) throw new Error(`API error: ${response.status}`);
      return await response.json();
    } catch (error) {
      console.error('API call failed:', error);
      return null;
    }
  }

  // Render items
  function renderItems(items: any[], containerId: string, countId: string) {
    const container = document.getElementById(containerId);
    const countEl = document.getElementById(countId);
    if (!container || !countEl) return;

    countEl.textContent = items.length.toString();
    container.innerHTML = items.map(item => `
      <div class="item-card" data-id="${item.id}">
        <div class="item-checkbox ${item.completed ? 'checked' : ''}" onclick="toggleItem('${item.id}')"></div>
        <div class="item-content">
          <div class="item-title ${item.completed ? 'completed' : ''}">${item.title}</div>
          <div class="item-meta">
            <span class="item-category">${item.category}</span>
            ${item.dueText ? `<span class="item-due">${item.dueText}</span>` : ''}
            ${item.priority ? `<span class="item-priority priority-${item.priority}">${item.priority === 'high' ? '高' : item.priority === 'medium' ? '中' : '低'}</span>` : ''}
          </div>
        </div>
        <div class="item-actions">
          <button class="item-btn" onclick="editItem('${item.id}')" title="编辑">✏️</button>
          <button class="item-btn delete" onclick="deleteItem('${item.id}')" title="删除">🗑️</button>
        </div>
      </div>
    `).join('');
  }

  // Render suggestions
  function renderSuggestions(suggestions: string[]) {
    const container = document.getElementById('suggestions-list');
    if (!container) return;

    container.innerHTML = suggestions.map(s => `
      <div class="suggestion-item">${s}</div>
    `).join('');
  }

  // Show results
  function showResults(result: any) {
    currentItems = [...result.done, ...result.todos, ...result.habits, ...result.bills, ...result.projects];

    // Hide empty state
    document.getElementById('empty-state')?.classList.add('hidden');

    // Show sections
    if (result.done.length > 0) {
      document.getElementById('done-section')?.classList.remove('hidden');
      renderItems(result.done, 'done-list', 'done-count');
    }
    if (result.todos.length > 0) {
      document.getElementById('todos-section')?.classList.remove('hidden');
      renderItems(result.todos, 'todos-list', 'todos-count');
    }
    if (result.habits.length > 0) {
      document.getElementById('habits-section')?.classList.remove('hidden');
      renderItems(result.habits, 'habits-list', 'habits-count');
    }
    if (result.bills.length > 0) {
      document.getElementById('bills-section')?.classList.remove('hidden');
      renderItems(result.bills, 'bills-list', 'bills-count');
    }
    if (result.projects.length > 0) {
      document.getElementById('projects-section')?.classList.remove('hidden');
      renderItems(result.projects, 'projects-list', 'projects-count');
    }
    if (result.suggestions.length > 0) {
      document.getElementById('suggestions-section')?.classList.remove('hidden');
      renderSuggestions(result.suggestions);
    }

    // Show action buttons
    document.getElementById('action-buttons')?.classList.remove('hidden');

    // Update mode badge
    const modeBadge = document.getElementById('mode-badge');
    if (modeBadge) {
      modeBadge.textContent = result.meta?.mode === 'api' ? 'API 模式' : '本地模式';
    }
    const durationBadge = document.getElementById('duration-badge');
    if (durationBadge && result.meta?.durationMs) {
      durationBadge.classList.remove('hidden');
      durationBadge.textContent = `${result.meta.durationMs}ms`;
    }
  }

  // Generate
  async function generate() {
    const text = lifeInput.value.trim();
    if (!text) {
      alert('请输入内容');
      return;
    }

    currentEntryText = text;
    btnGenerate.disabled = true;
    btnGenerate.textContent = '⏳ 解析中...';

    let result = null;
    if (apiBaseUrl) {
      result = await callApi(text);
    }

    if (!result) {
      result = parseLocally(text);
      result.meta = { mode: 'local-rules', durationMs: 0 };
    }

    showResults(result);
    btnGenerate.disabled = false;
    btnGenerate.textContent = '🚀 生成我的生活计划';

    // Save to history
    saveToHistory(text, result);
  }

  // Save to history
  function saveToHistory(text: string, result: any) {
    const history = JSON.parse(localStorage.getItem('mimo_lifepilot_history') || '[]');
    history.unshift({
      text,
      result,
      timestamp: new Date().toISOString(),
    });
    if (history.length > 50) history.pop();
    localStorage.setItem('mimo_lifepilot_history', JSON.stringify(history));
    renderHistory();
  }

  // Render history
  function renderHistory() {
    const history = JSON.parse(localStorage.getItem('mimo_lifepilot_history') || '[]');
    const container = document.getElementById('history-list');
    if (!container) return;

    if (history.length === 0) {
      container.innerHTML = '<p class="history-empty">暂无历史记录</p>';
      return;
    }

    container.innerHTML = history.slice(0, 10).map((item: any, index: number) => `
      <div class="history-item" onclick="loadHistory(${index})">
        <span class="history-date">${new Date(item.timestamp).toLocaleDateString('zh-CN')}</span>
        <span class="history-text">${item.text}</span>
        <span class="history-count">${item.result.done.length + item.result.todos.length} 项</span>
      </div>
    `).join('');
  }

  // Load history
  function loadHistory(index: number) {
    const history = JSON.parse(localStorage.getItem('mimo_lifepilot_history') || '[]');
    if (history[index]) {
      lifeInput.value = history[index].text;
      showResults(history[index].result);
    }
  }

  // Toggle item
  function toggleItem(id: string) {
    const item = currentItems.find(i => i.id === id);
    if (item) {
      item.completed = !item.completed;
      // Re-render
      const result = {
        done: currentItems.filter(i => i.status === 'done'),
        todos: currentItems.filter(i => i.status === 'todo'),
        habits: currentItems.filter(i => i.status === 'habit'),
        bills: currentItems.filter(i => i.status === 'bill'),
        projects: currentItems.filter(i => i.status === 'project'),
        suggestions: [],
        meta: { mode: 'local', durationMs: 0 },
      };
      showResults(result);
    }
  }

  // Edit item
  function editItem(id: string) {
    const item = currentItems.find(i => i.id === id);
    if (item) {
      const newTitle = prompt('编辑项目:', item.title);
      if (newTitle && newTitle.trim()) {
        item.title = newTitle.trim();
        const result = {
          done: currentItems.filter(i => i.status === 'done'),
          todos: currentItems.filter(i => i.status === 'todo'),
          habits: currentItems.filter(i => i.status === 'habit'),
          bills: currentItems.filter(i => i.status === 'bill'),
          projects: currentItems.filter(i => i.status === 'project'),
          suggestions: [],
          meta: { mode: 'local', durationMs: 0 },
        };
        showResults(result);
      }
    }
  }

  // Delete item
  function deleteItem(id: string) {
    if (confirm('确定删除这个项目吗？')) {
      currentItems = currentItems.filter(i => i.id !== id);
      const result = {
        done: currentItems.filter(i => i.status === 'done'),
        todos: currentItems.filter(i => i.status === 'todo'),
        habits: currentItems.filter(i => i.status === 'habit'),
        bills: currentItems.filter(i => i.status === 'bill'),
        projects: currentItems.filter(i => i.status === 'project'),
        suggestions: [],
        meta: { mode: 'local', durationMs: 0 },
      };
      showResults(result);
    }
  }

  // Save
  function save() {
    const saveMode = (document.getElementById('setting-save-mode') as HTMLSelectElement)?.value || 'local';
    
    if (saveMode === 'api' && apiBaseUrl) {
      // Save to API
      fetch(`${apiBaseUrl}/api/lifepilot/save-plan`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ entryText: currentEntryText, items: currentItems }),
      }).then(() => {
        alert('已保存到服务器');
      }).catch(() => {
        alert('保存失败，已保存到本地');
        saveToLocal();
      });
    } else {
      saveToLocal();
    }
  }

  function saveToLocal() {
    const entries = JSON.parse(localStorage.getItem('mimo_lifepilot_entries') || '[]');
    entries.unshift({
      entryText: currentEntryText,
      items: currentItems,
      timestamp: new Date().toISOString(),
    });
    if (entries.length > 100) entries.pop();
    localStorage.setItem('mimo_lifepilot_entries', JSON.stringify(entries));
    alert('已保存到本地');
  }

  // Export
  function exportMarkdown() {
    const done = currentItems.filter(i => i.status === 'done');
    const todos = currentItems.filter(i => i.status === 'todo');
    const habits = currentItems.filter(i => i.status === 'habit');
    const bills = currentItems.filter(i => i.status === 'bill');

    let md = `# 今日生活记录\n\n`;
    md += `**日期**: ${new Date().toLocaleDateString('zh-CN')}\n\n`;
    
    if (done.length > 0) {
      md += `## ✅ 已完成\n\n`;
      done.forEach(item => {
        md += `- [x] ${item.title}\n`;
      });
      md += '\n';
    }
    
    if (todos.length > 0) {
      md += `## 📋 待办事项\n\n`;
      todos.forEach(item => {
        md += `- [ ] ${item.title}${item.dueText ? ` (${item.dueText})` : ''}\n`;
      });
      md += '\n';
    }
    
    if (habits.length > 0) {
      md += `## 🏃 习惯记录\n\n`;
      habits.forEach(item => {
        md += `- ${item.title}\n`;
      });
      md += '\n';
    }
    
    if (bills.length > 0) {
      md += `## 💰 账单/支出\n\n`;
      bills.forEach(item => {
        md += `- ${item.title}\n`;
      });
      md += '\n';
    }
    
    md += `---\n*由 LifePilot AI 生活管家生成*`;

    const blob = new Blob([md], { type: 'text/markdown' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `生活记录-${new Date().toISOString().split('T')[0]}.md`;
    a.click();
    URL.revokeObjectURL(url);
  }

  // Event listeners
  btnGenerate?.addEventListener('click', generate);
  btnClear?.addEventListener('click', () => {
    lifeInput.value = '';
    document.getElementById('empty-state')?.classList.remove('hidden');
    document.getElementById('done-section')?.classList.add('hidden');
    document.getElementById('todos-section')?.classList.add('hidden');
    document.getElementById('habits-section')?.classList.add('hidden');
    document.getElementById('bills-section')?.classList.add('hidden');
    document.getElementById('projects-section')?.classList.add('hidden');
    document.getElementById('suggestions-section')?.classList.add('hidden');
    document.getElementById('action-buttons')?.classList.add('hidden');
  });
  btnUseExample?.addEventListener('click', () => {
    lifeInput.value = guideExample;
  });
  btnSave?.addEventListener('click', save);
  btnExport?.addEventListener('click', exportMarkdown);

  // Make functions globally available
  (window as any).toggleItem = toggleItem;
  (window as any).editItem = editItem;
  (window as any).deleteItem = deleteItem;
  (window as any).loadHistory = loadHistory;

  // Load history on init
  renderHistory();
</script>