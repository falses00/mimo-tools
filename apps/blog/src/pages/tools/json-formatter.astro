---
import Layout from '../../layouts/Layout.astro';
import ToolLayout from '../../components/tools/ToolLayout.astro';
---

<Layout title="JSON Formatter - MIMO">
  <ToolLayout title="JSON Formatter" description="格式化、压缩、验证 JSON 数据" icon="{ }">
    {/* Action Buttons */}
    <div class="flex flex-wrap gap-2 mb-6">
      <button id="btn-format" class="btn btn-primary">格式化</button>
      <button id="btn-minify" class="btn btn-secondary">压缩</button>
      <button id="btn-validate" class="btn btn-secondary">验证</button>
      <button id="btn-diff" class="btn btn-secondary">差异比较</button>
      <button id="btn-example" class="btn btn-ghost">示例</button>
      <button id="btn-copy" class="btn btn-ghost">复制结果</button>
      <button id="btn-clear" class="btn btn-ghost" style="color: var(--error);">清空</button>
    </div>

    {/* Indent Select */}
    <div class="mb-6">
      <label for="indent-select" class="text-sm mr-2" style="color: var(--text-muted);">缩进:</label>
      <select id="indent-select" class="input" style="width: auto; display: inline-block;">
        <option value="2" selected>2 空格</option>
        <option value="4">4 空格</option>
        <option value="tab">Tab</option>
      </select>
    </div>

    {/* Diff Section */}
    <div id="diff-section" class="hidden mb-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">JSON A</label>
          <textarea id="input-a" class="textarea" placeholder="粘贴第一个 JSON..."></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">JSON B</label>
          <textarea id="input-b" class="textarea" placeholder="粘贴第二个 JSON..."></textarea>
        </div>
      </div>
      <button id="btn-compare" class="btn btn-primary mt-4">比较</button>
    </div>

    {/* Single Section */}
    <div id="single-section" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">输入</label>
        <textarea id="input-json" class="textarea" style="min-height: 20rem;" placeholder="粘贴 JSON 数据..."></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">输出</label>
        <textarea id="output-json" class="textarea" style="min-height: 20rem;" readonly placeholder="结果将显示在这里..."></textarea>
      </div>
    </div>

    {/* Tips */}
    <div slot="tips" class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
      <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">使用说明</h3>
      <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">格式化</strong> - 将 JSON 数据美化为易读格式</span>
        </li>
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">压缩</strong> - 移除所有空白，生成最小 JSON</span>
        </li>
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">验证</strong> - 检查 JSON 语法是否正确</span>
        </li>
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">差异比较</strong> - 比较两个 JSON 对象的差异</span>
        </li>
      </ul>
    </div>
  </ToolLayout>
</Layout>

<script>
  const inputJson = document.getElementById('input-json') as HTMLTextAreaElement;
  const outputJson = document.getElementById('output-json') as HTMLTextAreaElement;
  const inputA = document.getElementById('input-a') as HTMLTextAreaElement;
  const inputB = document.getElementById('input-b') as HTMLTextAreaElement;
  const statusBar = document.getElementById('status-bar') as HTMLDivElement;
  const diffSection = document.getElementById('diff-section') as HTMLDivElement;
  const singleSection = document.getElementById('single-section') as HTMLDivElement;
  const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;

  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    if (!statusBar) return;
    statusBar.className = `mt-4 p-3 rounded-lg text-sm block`;
    statusBar.style.background = type === 'success' 
      ? 'var(--success-muted)' 
      : type === 'error' 
        ? 'var(--error-muted)' 
        : 'var(--info-muted)';
    statusBar.style.color = type === 'success' 
      ? 'var(--success)' 
      : type === 'error' 
        ? 'var(--error)' 
        : 'var(--info)';
    statusBar.textContent = msg;
  }

  function validateJson(input: string) {
    if (!input.trim()) return { valid: false, error: '输入不能为空' };
    try {
      JSON.parse(input);
      return { valid: true };
    } catch (e: any) {
      return { valid: false, error: e.message };
    }
  }

  function getIndent() {
    const v = indentSelect.value;
    return v === 'tab' ? '\t' : parseInt(v);
  }

  document.getElementById('btn-format')?.addEventListener('click', () => {
    const r = validateJson(inputJson.value);
    if (!r.valid) {
      showStatus('JSON 无效: ' + r.error, 'error');
      return;
    }
    outputJson.value = JSON.stringify(JSON.parse(inputJson.value), null, getIndent());
    showStatus('格式化成功', 'success');
  });

  document.getElementById('btn-minify')?.addEventListener('click', () => {
    const r = validateJson(inputJson.value);
    if (!r.valid) {
      showStatus('JSON 无效: ' + r.error, 'error');
      return;
    }
    outputJson.value = JSON.stringify(JSON.parse(inputJson.value));
    showStatus('压缩成功', 'success');
  });

  document.getElementById('btn-validate')?.addEventListener('click', () => {
    const r = validateJson(inputJson.value);
    showStatus(r.valid ? 'JSON 有效 ✓' : 'JSON 无效: ' + r.error, r.valid ? 'success' : 'error');
  });

  document.getElementById('btn-diff')?.addEventListener('click', () => {
    diffSection.classList.toggle('hidden');
    singleSection.classList.toggle('hidden');
  });

  document.getElementById('btn-compare')?.addEventListener('click', () => {
    const a = validateJson(inputA.value);
    const b = validateJson(inputB.value);
    if (!a.valid) {
      showStatus('JSON A 无效: ' + a.error, 'error');
      return;
    }
    if (!b.valid) {
      showStatus('JSON B 无效: ' + b.error, 'error');
      return;
    }
    const objA = JSON.parse(inputA.value);
    const objB = JSON.parse(inputB.value);
    const changes: string[] = [];
    
    function diff(p: any, c: any, path: string) {
      path = path || '';
      const keys = new Set([...Object.keys(p || {}), ...Object.keys(c || {})]);
      keys.forEach(k => {
        const fp = path ? path + '.' + k : k;
        if (!(k in (p || {}))) {
          changes.push('+ ' + fp + ': ' + JSON.stringify(c[k]));
        } else if (!(k in (c || {}))) {
          changes.push('- ' + fp + ': ' + JSON.stringify(p[k]));
        } else if (typeof p[k] === 'object' && typeof c[k] === 'object' && p[k] && c[k]) {
          diff(p[k], c[k], fp);
        } else if (JSON.stringify(p[k]) !== JSON.stringify(c[k])) {
          changes.push('~ ' + fp);
        }
      });
    }
    
    diff(objA, objB);
    outputJson.value = changes.length === 0 ? '无差异' : changes.join('\n');
    showStatus(changes.length === 0 ? '两个 JSON 完全相同' : '发现 ' + changes.length + ' 处差异', 'info');
  });

  document.getElementById('btn-example')?.addEventListener('click', () => {
    inputJson.value = JSON.stringify({
      name: 'MIMO',
      version: '1.0.0',
      tools: ['JSON Formatter', 'Markdown Previewer'],
      config: { theme: 'dark' }
    }, null, 2);
    showStatus('已加载示例', 'info');
  });

  document.getElementById('btn-copy')?.addEventListener('click', () => {
    if (!outputJson.value) {
      showStatus('没有可复制的内容', 'error');
      return;
    }
    navigator.clipboard.writeText(outputJson.value);
    showStatus('已复制到剪贴板', 'success');
  });

  document.getElementById('btn-clear')?.addEventListener('click', () => {
    inputJson.value = '';
    outputJson.value = '';
    inputA.value = '';
    inputB.value = '';
    statusBar.className = 'mt-4 p-3 rounded-lg text-sm hidden';
  });
</script>