---
import Layout from '../../layouts/Layout.astro';
import ToolLayout from '../../components/tools/ToolLayout.astro';
---

<Layout title="Text Utilities - MIMO">
  <ToolLayout title="Text Utilities" description="大小写转换、去空行、去首尾空格、统计字符/单词/行数" icon="Aa">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {/* Input */}
      <div>
        <label for="input-text" class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">输入文本</label>
        <textarea id="input-text" class="textarea" style="min-height: 16rem;" placeholder="在此输入文本..."></textarea>
      </div>

      {/* Output */}
      <div>
        <label for="output-text" class="block text-sm font-medium mb-2" style="color: var(--text-secondary);">输出结果</label>
        <textarea id="output-text" class="textarea" style="min-height: 16rem;" readonly placeholder="结果将显示在这里..."></textarea>
      </div>
    </div>

    {/* Action Buttons */}
    <div class="flex flex-wrap gap-2 mt-6">
      <button id="btn-uppercase" class="btn btn-primary">转大写</button>
      <button id="btn-lowercase" class="btn btn-primary">转小写</button>
      <button id="btn-capitalize" class="btn btn-secondary">首字母大写</button>
      <button id="btn-reverse" class="btn btn-secondary">反转</button>
      <button id="btn-trim" class="btn btn-secondary">去首尾空格</button>
      <button id="btn-remove-empty-lines" class="btn btn-secondary">去空行</button>
      <button id="btn-sort-lines" class="btn btn-secondary">排序行</button>
      <button id="btn-remove-duplicates" class="btn btn-secondary">去重行</button>
      <button id="btn-copy" class="btn btn-ghost">复制结果</button>
      <button id="btn-clear" class="btn btn-ghost" style="color: var(--error);">清空</button>
    </div>

    {/* Statistics */}
    <div class="mt-6 p-4 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
      <h3 class="text-sm font-medium mb-3" style="color: var(--text-secondary);">文本统计</h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        <div>
          <div class="text-xs" style="color: var(--text-muted);">字符数</div>
          <div id="stat-chars" class="text-2xl font-bold" style="color: var(--gold-primary);">0</div>
        </div>
        <div>
          <div class="text-xs" style="color: var(--text-muted);">单词数</div>
          <div id="stat-words" class="text-2xl font-bold" style="color: var(--gold-primary);">0</div>
        </div>
        <div>
          <div class="text-xs" style="color: var(--text-muted);">行数</div>
          <div id="stat-lines" class="text-2xl font-bold" style="color: var(--gold-primary);">0</div>
        </div>
        <div>
          <div class="text-xs" style="color: var(--text-muted);">段落数</div>
          <div id="stat-paragraphs" class="text-2xl font-bold" style="color: var(--gold-primary);">0</div>
        </div>
      </div>
    </div>

    {/* Tips */}
    <div slot="tips" class="p-6 rounded-xl" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
      <h3 class="text-lg font-semibold mb-4" style="color: var(--text-primary);">使用说明</h3>
      <ul class="space-y-2 text-sm" style="color: var(--text-muted);">
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">转大写/小写</strong> - 批量转换字母大小写</span>
        </li>
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">首字母大写</strong> - 每个单词首字母大写</span>
        </li>
        <li class="flex items-start gap-2">
          <span style="color: var(--gold-primary);">•</span>
          <span><strong style="color: var(--text-secondary);">去空行/去重</strong> - 清理文本格式</span>
        </li>
      </ul>
    </div>
  </ToolLayout>
</Layout>

<script>
  const inputText = document.getElementById('input-text') as HTMLTextAreaElement;
  const outputText = document.getElementById('output-text') as HTMLTextAreaElement;
  const statusBar = document.getElementById('status-bar') as HTMLDivElement;
  const statChars = document.getElementById('stat-chars') as HTMLDivElement;
  const statWords = document.getElementById('stat-words') as HTMLDivElement;
  const statLines = document.getElementById('stat-lines') as HTMLDivElement;
  const statParagraphs = document.getElementById('stat-paragraphs') as HTMLDivElement;

  function showStatus(msg: string, type: 'success' | 'error' | 'info') {
    if (!statusBar) return;
    statusBar.className = `mt-4 p-3 rounded-lg text-sm block`;
    statusBar.style.background = type === 'success' ? 'var(--success-muted)' : type === 'error' ? 'var(--error-muted)' : 'var(--info-muted)';
    statusBar.style.color = type === 'success' ? 'var(--success)' : type === 'error' ? 'var(--error)' : 'var(--info)';
    statusBar.textContent = msg;
  }

  function updateStats(text: string) {
    const chars = text.length;
    const words = text.trim() ? text.trim().split(/\s+/).length : 0;
    const lines = text ? text.split('\n').length : 0;
    const paragraphs = text.trim() ? text.trim().split(/\n\s*\n/).length : 0;

    statChars.textContent = chars.toString();
    statWords.textContent = words.toString();
    statLines.textContent = lines.toString();
    statParagraphs.textContent = paragraphs.toString();
  }

  function processText(processor: (text: string) => string) {
    const input = inputText.value;
    if (!input.trim()) {
      showStatus('请输入文本', 'error');
      return;
    }
    outputText.value = processor(input);
    updateStats(outputText.value);
    showStatus('处理成功', 'success');
  }

  document.getElementById('btn-uppercase')?.addEventListener('click', () => processText(text => text.toUpperCase()));
  document.getElementById('btn-lowercase')?.addEventListener('click', () => processText(text => text.toLowerCase()));
  document.getElementById('btn-capitalize')?.addEventListener('click', () => processText(text => text.replace(/\b\w/g, l => l.toUpperCase())));
  document.getElementById('btn-reverse')?.addEventListener('click', () => processText(text => text.split('').reverse().join('')));
  document.getElementById('btn-trim')?.addEventListener('click', () => processText(text => text.split('\n').map(line => line.trim()).join('\n')));
  document.getElementById('btn-remove-empty-lines')?.addEventListener('click', () => processText(text => text.split('\n').filter(line => line.trim()).join('\n')));
  document.getElementById('btn-sort-lines')?.addEventListener('click', () => processText(text => text.split('\n').sort().join('\n')));
  document.getElementById('btn-remove-duplicates')?.addEventListener('click', () => processText(text => [...new Set(text.split('\n'))].join('\n')));

  document.getElementById('btn-copy')?.addEventListener('click', () => {
    if (!outputText.value) { showStatus('没有可复制的内容', 'error'); return; }
    navigator.clipboard.writeText(outputText.value);
    showStatus('已复制到剪贴板', 'success');
  });

  document.getElementById('btn-clear')?.addEventListener('click', () => {
    inputText.value = '';
    outputText.value = '';
    statusBar.className = 'mt-4 p-3 rounded-lg text-sm hidden';
    updateStats('');
  });

  inputText?.addEventListener('input', () => updateStats(inputText.value));
</script>