---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;

const techStack = [
  { category: '前端', items: ['Astro', 'React', 'TypeScript', 'Tailwind CSS', 'Three.js'] },
  { category: '后端', items: ['Node.js', 'Fastify', 'TypeScript'] },
  { category: '数据库', items: ['Supabase', 'PostgreSQL', 'localStorage'] },
  { category: 'AI/RAG', items: ['MiniSearch', 'TF-IDF', '关键词检索'] },
  { category: 'DevOps', items: ['GitHub Actions', 'Render', 'GitHub Pages'] },
  { category: '测试', items: ['Vitest', 'Playwright'] },
  { category: '工具', items: ['OpenCode', 'Multi-Agent', 'Harness'] },
];

const projects = [
  { name: 'LifePilot', desc: 'AI 生活管家', status: 'production' },
  { name: 'InterviewPilot', desc: 'AI 面试教练', status: 'production' },
  { name: 'RepoPilot', desc: 'GitHub 安全审查', status: 'production' },
  { name: 'KnowledgePilot', desc: 'RAG 助手', status: 'production' },
  { name: 'OpsPilot', desc: 'API/日志监控', status: 'production' },
  { name: 'MIMO Utilities', desc: '工具集合', status: 'production' },
];

const learningDirections = [
  'AI 应用开发与 RAG 检索',
  '全栈工程与 API 设计',
  '多 Agent 自动化工作流',
  '前端 3D 视觉与主题系统',
  'DevOps 与部署自动化',
  '产品设计与用户体验',
];
---

<Layout title="关于 - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">个人资料总结</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          👋 关于我
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          全栈工程师 / AI 工程师，专注于 AI 应用、全栈开发和多 Agent 工作流
        </p>
      </div>

      {/* Personal Intro */}
      <div class="content-card mb-8">
        <h2 class="card-title">个人简介</h2>
        <p class="card-text">
          我是一名全栈工程师，专注于 AI 应用开发、全栈工程和多 Agent 自动化工作流。
          我相信好的工程实践应该是：代码清晰、测试完整、部署可靠、文档齐全。
        </p>
        <p class="card-text">
          这个个人站展示了我的项目生态：6 个独立完整产品，每个都有自己的前后端、数据库、测试和部署方案。
          我也在这里记录学习资料、技术分析和项目复盘。
        </p>
      </div>

      {/* Tech Stack */}
      <div class="content-card mb-8">
        <h2 class="card-title">技术栈</h2>
        <div class="tech-grid">
          {techStack.map(group => (
            <div class="tech-group">
              <h3 class="tech-category">{group.category}</h3>
              <div class="tech-items">
                {group.items.map(item => (
                  <span class="tech-item">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Current Projects */}
      <div class="content-card mb-8">
        <h2 class="card-title">当前项目生态</h2>
        <div class="projects-list">
          {projects.map(project => (
            <div class="project-item">
              <span class="project-name">{project.name}</span>
              <span class="project-desc">{project.desc}</span>
              <span class:list={['badge', project.status === 'production' ? 'badge-success' : 'badge-gold']}>
                {project.status === 'production' ? '已上线' : '开发中'}
              </span>
            </div>
          ))}
        </div>
      </div>

      {/* Learning Directions */}
      <div class="content-card mb-8">
        <h2 class="card-title">学习方向</h2>
        <ul class="learning-list">
          {learningDirections.map(direction => (
            <li class="learning-item">{direction}</li>
          ))}
        </ul>
      </div>

      {/* Multi-Agent Workflow */}
      <div class="content-card mb-8">
        <h2 class="card-title">多 Agent 开发流程</h2>
        <p class="card-text">
          我使用 OpenCode 多 Agent 系统进行长链路自主开发。每个项目都经过：
        </p>
        <ul class="workflow-list">
          <li>产品规划与苏格拉底式自问</li>
          <li>竞品分析与技术选型</li>
          <li>前端实现与视觉审查</li>
          <li>后端 API 开发与测试</li>
          <li>数据库/RAG 策略设计</li>
          <li>安全审查与路径检查</li>
          <li>E2E 测试与 Playwright 验证</li>
          <li>部署与线上验收</li>
        </ul>
      </div>

      {/* Contact */}
      <div class="content-card">
        <h2 class="card-title">联系方式</h2>
        <div class="contact-links">
          <a href="https://github.com/falses00" target="_blank" rel="noopener noreferrer" class="btn btn-ghost">
            GitHub
          </a>
          <a href={`${baseWithSlash}projects`} class="btn btn-ghost">
            查看项目
          </a>
          <a href={`${baseWithSlash}learning`} class="btn btn-ghost">
            学习资料
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .content-card { padding: 2rem; border-radius: 1rem; background: var(--bg-card); border: 1px solid var(--border-subtle); }
  .card-title { font-size: 1.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 1.5rem; }
  .card-text { color: var(--text-secondary); margin-bottom: 1rem; line-height: 1.6; }
  .tech-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1.5rem; }
  .tech-category { font-size: 0.875rem; font-weight: 600; color: var(--gold); margin-bottom: 0.75rem; }
  .tech-items { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tech-item { padding: 0.375rem 0.75rem; border-radius: 0.375rem; background: var(--bg-elevated); font-size: 0.8rem; color: var(--text-secondary); }
  .projects-list { display: flex; flex-direction: column; gap: 0.75rem; }
  .project-item { display: flex; align-items: center; gap: 1rem; padding: 1rem; border-radius: 0.5rem; background: var(--bg-elevated); }
  .project-name { font-weight: 600; color: var(--text-primary); min-width: 150px; }
  .project-desc { flex: 1; color: var(--text-muted); }
  .learning-list { list-style: none; padding: 0; }
  .learning-item { padding: 0.75rem 0; border-bottom: 1px solid var(--border-subtle); color: var(--text-secondary); }
  .learning-item:last-child { border-bottom: none; }
  .workflow-list { list-style: disc; padding-left: 1.5rem; }
  .workflow-list li { padding: 0.5rem 0; color: var(--text-secondary); }
  .contact-links { display: flex; flex-wrap: wrap; gap: 1rem; }
</style>