---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于 - MIMO">
  <div class="section">
    <div class="container-sm">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">关于</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4" style="color: var(--text-primary);">
          关于 MIMO
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          个人工具生态：包含多个实用工具、博客和导航站
        </p>
      </div>

      {/* Content */}
      <div class="space-y-12">
        {/* Mission */}
        <div class="p-8 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <h2 class="text-2xl font-bold mb-4" style="color: var(--gold-primary);">使命</h2>
          <p class="text-lg leading-relaxed" style="color: var(--text-secondary);">
            MIMO 旨在为开发者提供一组高质量、易用、免费的在线工具。所有工具都采用纯前端实现，
            确保用户数据不会离开浏览器，保护隐私安全。
          </p>
        </div>

        {/* Features */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
              <span class="text-2xl" style="color: var(--gold-primary);">🔒</span>
            </div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">隐私优先</h3>
            <p class="text-sm" style="color: var(--text-muted);">
              所有数据处理都在浏览器本地完成，不会上传到任何服务器。您的数据完全由您控制。
            </p>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
              <span class="text-2xl" style="color: var(--gold-primary);">⚡</span>
            </div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">快速高效</h3>
            <p class="text-sm" style="color: var(--text-muted);">
              基于 Astro 静态生成，页面加载速度极快。工具响应迅速，无需等待。
            </p>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
              <span class="text-2xl" style="color: var(--gold-primary);">🎨</span>
            </div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">精美设计</h3>
            <p class="text-sm" style="color: var(--text-muted);">
              采用暗金主题设计，界面简洁优雅。支持深色/浅色模式，响应式布局。
            </p>
          </div>

          <div class="p-6 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl mb-4" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
              <span class="text-2xl" style="color: var(--gold-primary);">🛠️</span>
            </div>
            <h3 class="text-lg font-semibold mb-2" style="color: var(--text-primary);">开源免费</h3>
            <p class="text-sm" style="color: var(--text-muted);">
              项目完全开源，代码托管在 GitHub。欢迎贡献代码和提出建议。
            </p>
          </div>
        </div>

        {/* Tech Stack */}
        <div class="p-8 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--border-subtle);">
          <h2 class="text-2xl font-bold mb-6" style="color: var(--gold-primary);">技术栈</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
            {['Astro', 'Tailwind CSS', 'TypeScript', 'Playwright'].map(tech => (
              <div class="p-4 rounded-lg text-center" style="background: var(--bg-elevated); border: 1px solid var(--border-subtle);">
                <div class="font-medium" style="color: var(--text-primary);">{tech}</div>
              </div>
            ))}
          </div>
        </div>

        {/* GitHub */}
        <div class="text-center p-8 rounded-xl" style="background: var(--bg-card); border: 1px solid var(--gold-border);">
          <h2 class="text-2xl font-bold mb-4" style="color: var(--text-primary);">参与贡献</h2>
          <p class="mb-6" style="color: var(--text-muted);">
            欢迎在 GitHub 上提交 Issue 和 Pull Request
          </p>
          <a
            href="https://github.com/falses00/mimo-tools"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary px-8 py-3"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2">
              <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
              <path d="M9 18c-4.51 2-5-2-7-2" />
            </svg>
            GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>