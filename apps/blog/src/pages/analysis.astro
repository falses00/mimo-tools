---
import Layout from '../layouts/Layout.astro';
import { analysisReports } from '../data/analysis';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;

const categories = [
  { id: 'competitor', name: '竞品分析', icon: '🔍' },
  { id: 'tech-selection', name: '技术选型', icon: '⚙️' },
  { id: 'opensource', name: '开源项目分析', icon: '📦' },
  { id: 'dataset', name: '数据集分析', icon: '📊' },
  { id: 'architecture', name: '架构复盘', icon: '🏗️' },
  { id: 'security', name: '安全分析', icon: '🔒' },
];
---

<Layout title="资料分析总结 - MIMO">
  <div class="section">
    <div class="container">
      {/* Header */}
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold-soft);">资料分析总结</span>
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          📊 资料分析总结
        </h1>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          沉淀项目调研、竞品分析、技术选型、数据集分析和架构复盘
        </p>
      </div>

      {/* Categories */}
      <div class="flex flex-wrap justify-center gap-3 mb-12">
        <button class="btn btn-primary category-btn" data-category="all">全部</button>
        {categories.map(cat => (
          <button class="btn btn-secondary category-btn" data-category={cat.id}>
            {cat.icon} {cat.name}
          </button>
        ))}
      </div>

      {/* Reports Grid */}
      <div id="reports-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {analysisReports.map(report => (
          <a
            href={`${baseWithSlash}analysis/${report.slug}`}
            class="group block rounded-xl p-6 transition-all duration-300 report-card"
            style="background: var(--bg-card); border: 1px solid var(--border-subtle);"
            data-category={report.category}
          >
            <div class="flex items-center gap-2 mb-4">
              <span class="badge badge-gold text-xs">{report.category}</span>
              <span class="text-xs" style="color: var(--text-muted);">{report.date}</span>
            </div>
            <h2 class="text-lg font-semibold mb-2 group-hover:text-[var(--gold-primary)] transition-colors" style="color: var(--text-primary);">
              {report.title}
            </h2>
            <p class="text-sm mb-4" style="color: var(--text-muted);">
              {report.description}
            </p>
            <div class="p-3 rounded-lg mb-4" style="background: var(--bg-elevated);">
              <div class="text-xs font-semibold mb-1" style="color: var(--gold);">结论</div>
              <div class="text-sm" style="color: var(--text-secondary);">{report.conclusion}</div>
            </div>
            <div class="flex flex-wrap gap-2">
              {report.tags.slice(0, 3).map(tag => (
                <span class="badge text-xs" style="background: var(--bg-elevated); border-color: var(--border-subtle); color: var(--text-muted);">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  const categoryBtns = document.querySelectorAll('.category-btn');
  const reportCards = document.querySelectorAll('.report-card');

  let currentCategory = 'all';

  function filterReports() {
    reportCards.forEach(card => {
      const category = card.getAttribute('data-category') || '';
      if (currentCategory === 'all' || category === currentCategory) {
        (card as HTMLElement).style.display = '';
      } else {
        (card as HTMLElement).style.display = 'none';
      }
    });
  }

  categoryBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category') || 'all';
      currentCategory = category;

      categoryBtns.forEach(b => {
        b.classList.remove('btn-primary');
        b.classList.add('btn-secondary');
      });
      btn.classList.remove('btn-secondary');
      btn.classList.add('btn-primary');

      filterReports();
    });
  });
</script>