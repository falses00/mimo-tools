---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import ThreeDCard from '../components/visual/ThreeDCard.astro';
import { getFeaturedProjects } from '../data/flagship-projects';

const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
const featuredProjects = getFeaturedProjects();
---

<Layout title="MIMO - 个人工程工具生态">
  <Hero />
  
  {/* Flagship Projects Section */}
  <section class="section relative">
    <div class="container">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold);">旗舰项目</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          Flagship Projects
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          真正有技术含量的工程项目，展示质量审计、数据分析、API 工具、故障分析、知识检索能力
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
        {featuredProjects.map(project => (
          <ThreeDCard href={`${baseWithSlash}projects/${project.id}`} featured>
            <div class="p-8">
              <div class="flex items-start gap-4 mb-6">
                <div class="flex items-center justify-center w-16 h-16 rounded-2xl flex-shrink-0" style="background: var(--gold-subtle); border: 1px solid var(--gold-border);">
                  <span class="text-3xl">{project.icon}</span>
                </div>
                <div>
                  <h3 class="text-xl font-bold mb-1" style="color: var(--text-primary);">
                    {project.name}
                  </h3>
                  <p class="text-sm" style="color: var(--gold-soft);">{project.tagline}</p>
                </div>
              </div>
              <p class="mb-6" style="color: var(--text-secondary);">
                {project.description}
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                {project.capabilities.slice(0, 4).map(cap => (
                  <span class="badge-gold">{cap}</span>
                ))}
              </div>
              <div class="flex flex-wrap gap-2">
                {project.techStack.slice(0, 3).map(tech => (
                  <span class="text-xs px-2 py-1 rounded" style="background: var(--bg-surface); color: var(--text-muted);">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </ThreeDCard>
        ))}
      </div>

      <div class="text-center">
        <a href={`${baseWithSlash}projects`} class="btn-gold inline-flex items-center gap-2">
          查看所有旗舰项目
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  {/* Quick Utilities Section */}
  <section class="section relative">
    <div class="container">
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 glass-panel">
          <span class="text-xs font-medium" style="color: var(--gold);">Quick Utilities</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-6" style="color: var(--text-primary);">
          组合工具套件
        </h2>
        <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
          6 个精心设计的组合工具，覆盖格式化、编码、时间、设计等常用场景
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: '📝', name: 'Format Studio', desc: 'JSON/YAML/TOML 格式化与验证', href: '/tools/json-formatter' },
          { icon: '✍️', name: 'Markdown Studio', desc: 'Markdown 预览、TOC、统计', href: '/tools/markdown-previewer' },
          { icon: '🔤', name: 'Regex Studio', desc: '正则表达式测试与模板', href: '/tools/regex-tester' },
          { icon: '🔗', name: 'Encode Studio', desc: 'URL/Base64/HTML 编码解码', href: '/tools/url-encoder' },
          { icon: '⏱️', name: 'Time & ID Studio', desc: '时间戳、Cron、UUID 生成', href: '/tools/timestamp-converter' },
          { icon: '🎨', name: 'Design Utility', desc: '颜色、对比度、Token 预览', href: '/tools/color-palette' },
        ].map(tool => (
          <ThreeDCard href={`${baseWithSlash}${tool.href.substring(1)}`}>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-4">
                <span class="text-2xl">{tool.icon}</span>
                <h3 class="text-lg font-semibold" style="color: var(--text-primary);">
                  {tool.name}
                </h3>
              </div>
              <p class="text-sm" style="color: var(--text-muted);">{tool.desc}</p>
            </div>
          </ThreeDCard>
        ))}
      </div>

      <div class="text-center mt-12">
        <a href={`${baseWithSlash}tools`} class="btn-ghost inline-flex items-center gap-2">
          查看所有工具
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Layout>