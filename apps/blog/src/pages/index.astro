---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MIMO - 个人工具生态">
  <main class="flex min-h-screen flex-col items-center justify-center p-24">
    <div class="z-10 max-w-5xl w-full items-center justify-between font-mono text-sm lg:flex">
      <p class="fixed left-0 top-0 flex w-full justify-center border-b border-gray-300 bg-gradient-to-b from-zinc-200 pb-6 pt-8 backdrop-blur-2xl dark:border-neutral-800 dark:bg-zinc-800/30 dark:from-inherit lg:static lg:w-auto lg:rounded-xl lg:border lg:bg-gray-200 lg:p-4 lg:dark:bg-zinc-800/30">
        欢迎来到 MIMO 工具站
      </p>
      <div class="fixed bottom-0 left-0 flex h-48 w-full items-end justify-center bg-gradient-to-t from-white via-white dark:from-black dark:via-black lg:static lg:h-auto lg:w-auto lg:bg-none">
        <a href="https://github.com/yourusername/mimo" class="pointer-events-none flex place-items-center gap-2 p-8 lg:pointer-events-auto lg:p-0" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
      </div>
    </div>

    <div class="relative z-[-1] flex place-items-center before:absolute before:h-[300px] before:w-full sm:before:w-[480px] before:-translate-x-1/2 before:rounded-full before:bg-gradient-radial before:from-white before:to-transparent before:blur-2xl before:content-[''] after:absolute after:-z-20 after:h-[180px] after:w-full sm:after:w-[240px] after:translate-x-1/3 after:bg-gradient-conic after:from-sky-200 after:via-blue-200 after:blur-2xl after:content-[''] before:dark:bg-gradient-to-br before:dark:from-transparent before:dark:to-blue-700 before:dark:opacity-10 after:dark:from-sky-900 after:dark:via-[#0141ff] after:dark:opacity-40 before:lg:h-[360px]">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-6xl">MIMO</h1>
    </div>

    <div class="mb-32 grid text-center lg:max-w-5xl lg:w-full lg:mb-0 lg:grid-cols-4 lg:text-left">
      <a href="/tools" class="group rounded-lg border border-transparent px-5 py-4 transition-colors hover:border-gray-300 hover:bg-gray-100 hover:dark:border-neutral-700 hover:dark:bg-neutral-800/30">
        <h2 class="mb-3 text-2xl font-semibold">工具 <span class="inline-block transition-transform group-hover:translate-x-1 motion-reduce:transform-none">&rarr;</span></h2>
        <p class="m-0 max-w-[30ch] text-sm opacity-50">实用开发工具集合</p>
      </a>
      <a href="/blog" class="group rounded-lg border border-transparent px-5 py-4 transition-colors hover:border-gray-300 hover:bg-gray-100 hover:dark:border-neutral-700 hover:dark:bg-neutral-800/30">
        <h2 class="mb-3 text-2xl font-semibold">博客 <span class="inline-block transition-transform group-hover:translate-x-1 motion-reduce:transform-none">&rarr;</span></h2>
        <p class="m-0 max-w-[30ch] text-sm opacity-50">技术文章与分享</p>
      </a>
      <a href="https://github.com/yourusername/mimo" class="group rounded-lg border border-transparent px-5 py-4 transition-colors hover:border-gray-300 hover:bg-gray-100 hover:dark:border-neutral-700 hover:dark:bg-neutral-800/30" target="_blank" rel="noopener noreferrer">
        <h2 class="mb-3 text-2xl font-semibold">GitHub <span class="inline-block transition-transform group-hover:translate-x-1 motion-reduce:transform-none">&rarr;</span></h2>
        <p class="m-0 max-w-[30ch] text-sm opacity-50">查看源代码</p>
      </a>
      <a href="/about" class="group rounded-lg border border-transparent px-5 py-4 transition-colors hover:border-gray-300 hover:bg-gray-100 hover:dark:border-neutral-700 hover:dark:bg-neutral-800/30">
        <h2 class="mb-3 text-2xl font-semibold">关于 <span class="inline-block transition-transform group-hover:translate-x-1 motion-reduce:transform-none">&rarr;</span></h2>
        <p class="m-0 max-w-[30ch] text-sm opacity-50">了解更多关于我</p>
      </a>
    </div>
  </main>
</Layout>
