---
import Layout from '../../layouts/Layout.astro';
import { learningArticles, getLearningBySlug } from '../../data/learning';

export function getStaticPaths() {
  return learningArticles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const base = import.meta.env.BASE_URL;
const baseWithSlash = base.endsWith('/') ? base : `${base}/`;
---

<Layout title={`${article.title} - 学习资料`}>
  <div class="section">
    <div class="container-sm">
      {/* Back Link */}
      <a href={`${baseWithSlash}learning`} class="inline-flex items-center gap-2 text-sm mb-8 transition-colors duration-200" style="color: var(--text-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7" />
          <path d="M19 12H5" />
        </svg>
        返回学习资料中心
      </a>

      {/* Article */}
      <article>
        {/* Header */}
        <div class="mb-12">
          <div class="flex items-center gap-2 mb-4">
            <span class="badge badge-gold text-xs">{article.category}</span>
            <span class="text-sm" style="color: var(--text-muted);">{article.readingTime}</span>
            <span class="text-sm" style="color: var(--text-muted);">{article.date}</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="color: var(--text-primary);">
            {article.title}
          </h1>
          <p class="text-xl leading-relaxed" style="color: var(--text-secondary);">
            {article.description}
          </p>
          <div class="flex flex-wrap gap-2 mt-6">
            {article.tags.map(tag => (
              <span class="badge badge-gold text-xs">{tag}</span>
            ))}
          </div>
        </div>

        {/* Content */}
        <div class="prose-custom" set:html={article.content.replace(/\n/g, '<br/>')} />

        {/* Footer */}
        <div class="mt-16 pt-8" style="border-top: 1px solid var(--border-subtle);">
          <a href={`${baseWithSlash}learning`} class="btn btn-secondary">
            返回学习资料中心
          </a>
        </div>
      </article>
    </div>
  </div>
</Layout>

<style>
  .container-sm {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .prose-custom {
    color: var(--text-secondary);
    line-height: 1.75;
  }
  
  .prose-custom :global(h2) {
    color: var(--text-primary);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose-custom :global(h3) {
    color: var(--text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose-custom :global(p) {
    margin-bottom: 1rem;
  }
  
  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  
  .prose-custom :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .prose-custom :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  
  .prose-custom :global(th),
  .prose-custom :global(td) {
    padding: 0.75rem;
    border: 1px solid var(--border-subtle);
    text-align: left;
  }
  
  .prose-custom :global(th) {
    background: var(--bg-elevated);
    color: var(--text-primary);
    font-weight: 600;
  }
</style>