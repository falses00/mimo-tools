---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout title={`${post.data.title} - MIMO`}>
  <div class="section">
    <div class="container-sm">
      {/* Back Link */}
      <a href="/mimo-tools/blog" class="inline-flex items-center gap-2 text-sm mb-8 transition-colors duration-200" style="color: var(--text-muted);">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7" />
          <path d="M19 12H5" />
        </svg>
        返回博客
      </a>

      {/* Article */}
      <article>
        {/* Header */}
        <div class="mb-12">
          {/* Date */}
          <div class="flex items-center gap-2 mb-4">
            <time class="text-sm" style="color: var(--text-muted);" datetime={post.data.date}>
              {new Date(post.data.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>

          {/* Title */}
          <h1 class="text-4xl sm:text-5xl font-bold mb-6" style="color: var(--text-primary);">
            {post.data.title}
          </h1>

          {/* Description */}
          <p class="text-xl leading-relaxed mb-6" style="color: var(--text-secondary);">
            {post.data.description}
          </p>

          {/* Tags */}
          <div class="flex flex-wrap gap-2">
            {post.data.tags?.map(tag => (
              <span class="badge badge-gold text-xs">
                {tag}
              </span>
            ))}
          </div>

          {/* Divider */}
          <div class="mt-8 divider-gold" style="height: 1px;"></div>
        </div>

        {/* Content */}
        <div class="prose-custom">
          <Content />
        </div>

        {/* Footer */}
        <div class="mt-16 pt-8" style="border-top: 1px solid var(--border-subtle);">
          <a href="/mimo-tools/blog" class="btn btn-secondary">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m12 19-7-7 7-7" />
              <path d="M19 12H5" />
            </svg>
            返回博客列表
          </a>
        </div>
      </article>
    </div>
  </div>
</Layout>

<style>
  .prose-custom {
    color: var(--text-secondary);
    line-height: 1.75;
  }
  
  .prose-custom :global(h2) {
    color: var(--text-primary);
    font-size: 1.5rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose-custom :global(h3) {
    color: var(--text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose-custom :global(p) {
    margin-bottom: 1rem;
  }
  
  .prose-custom :global(a) {
    color: var(--gold-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  
  .prose-custom :global(a:hover) {
    color: var(--gold-soft);
  }
  
  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  
  .prose-custom :global(li) {
    margin-bottom: 0.5rem;
  }
  
  .prose-custom :global(blockquote) {
    border-left: 3px solid var(--gold-border);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--text-muted);
    font-style: italic;
  }
  
  .prose-custom :global(code) {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
  }
  
  .prose-custom :global(pre) {
    margin: 1.5rem 0;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    background: var(--bg-elevated) !important;
    border: 1px solid var(--border-default);
  }
  
  .prose-custom :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
  }
  
  .prose-custom :global(img) {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
  
  .prose-custom :global(hr) {
    margin: 2rem 0;
    border: none;
    height: 1px;
    background: var(--border-subtle);
  }
  
  .prose-custom :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  
  .prose-custom :global(th),
  .prose-custom :global(td) {
    padding: 0.75rem;
    border: 1px solid var(--border-subtle);
    text-align: left;
  }
  
  .prose-custom :global(th) {
    background: var(--bg-elevated);
    color: var(--text-primary);
    font-weight: 600;
  }
</style>